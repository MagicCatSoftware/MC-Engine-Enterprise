    "M10": {
      "id": "M10", "label": "run_btn", "tag": "button",
      "text": "Run Logic",
      "parentId": "M5", "children": [],
      "css": {
        "padding": "11px 28px",
        "background": "#a78bfa",
        "color": "#000000",
        "fontWeight": "700",
        "fontSize": "14px",
        "border": "none",
        "borderRadius": "6px",
        "cursor": "pointer",
        "display": "inline-block"
      },
      "attrs": {
        "onclick": "var _n=document.querySelector('[data-mce-id=M8]'); var _s=document.querySelector('[data-mce-id=M9]'); var ctx={name:(_n?_n.value:'').trim(),score:(_s?_s.value:'').trim()}; if(typeof LogicSystem!=='undefined')LogicSystem.run('M10',ctx); else if(typeof MachineSystem!=='undefined')MachineSystem.executeLogic('M10',ctx);"
      },
      "wires": [],
      "viewBinding": null
    },

    "M11": {
      "id": "M11", "label": "result_panel", "tag": "div",
      "text": "", "parentId": "M5", "children": ["M12", "M13"],
      "css": {
