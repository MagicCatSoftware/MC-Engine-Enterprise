    "M2": {
      "id": "M2", "label": "nav_bar", "tag": "nav",
      "text": "", "parentId": "M1", "children": ["M3", "M4"],
      "css": {
        "display": "flex",
        "alignItems": "center",
        "gap": "8px",
        "padding": "14px 40px",
        "background": "#0d0d1a",
        "borderBottom": "1px solid #1e1e3e"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M3": {
      "id": "M3", "label": "btn_grade", "tag": "button",
