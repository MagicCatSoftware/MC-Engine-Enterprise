      "css": { "padding": "52px 40px", "maxWidth": "580px" },
      "attrs": {},
      "wires": [],
      "viewBinding": "grade"
    },

    "M6": {
      "id": "M6", "label": "grade_title", "tag": "h1",
      "text": "Logic Panel Demo",
      "parentId": "M5", "children": [],
      "css": {
        "color": "#e2e8f0",
        "fontSize": "34px",
