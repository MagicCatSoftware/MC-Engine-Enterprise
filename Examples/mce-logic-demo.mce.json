{
  "version": "1.0.0",
  "project": { "name": "Logic Panel Demo — Grade Calculator" },
  "_nextId": 22,
  "runtimeStyle": "ocean",
  "rootOrder": ["M1"],

  "events": {
    "navGrade":   { "name": "navGrade",   "payload": "{}" },
    "navHistory": { "name": "navHistory", "payload": "{}" },
    "gradeAdded": { "name": "gradeAdded", "payload": "{ value } — summary string emitted by Logic code" }
  },

  "pipes": {
    "loadHistory": {
      "name": "loadHistory",
      "method": "GET",
      "endpoint": "/api/showcase/grades",
      "collection": "grades",
      "delay": 0,
      "schema": [],
      "live": false
    }
  },

  "views": {
    "grade": {
      "name": "grade",
      "title": "Grade",
      "description": "Default view — form that runs the Logic chain.",
      "params": []
    },
    "history": {
      "name": "history",
      "title": "History",
      "description": "View:history event triggers pipeOut loadHistory, Loop renders all grades from DB.",
      "params": []
    }
  },

  "loops": {
    "historyLoop": {
      "name": "historyLoop",
      "pipeName": "loadHistory",
      "targetId": "M21",
      "template": "<div style=\"background:#13131f;border:1px solid #2e2e4e;border-radius:10px;padding:18px 20px;flex:1;min-width:180px;max-width:240px;text-align:center\"><div style=\"font-size:52px;font-weight:900;color:#a78bfa;line-height:1;margin-bottom:8px\">{{grade}}</div><div style=\"font-size:14px;font-weight:700;color:#e2e8f0;margin-bottom:4px\">{{name}}</div><div style=\"font-size:13px;color:#64748b;margin-bottom:6px\">Score: {{score}}</div><div style=\"font-size:11px;color:#334155\">{{date}}</div></div>"
    }
  },

  "vars": {
    "passMark": { "value": "60", "desc": "Minimum score to pass — used in the ELSEIF condition inside Logic" }
  },

  "logic": {
    "M10": {
      "blocks": [

        {
          "type": "if",
          "condition": "!ctx.name",
          "code": "",
          "actions": [
            { "targetId": "M14", "action": "show",    "actionArgs": "" },
            { "targetId": "M14", "action": "setText", "actionArgs": "Name is required." },
            { "targetId": "M11", "action": "hide",    "actionArgs": "" }
          ],
          "children": []
        },

        {
          "type": "elseif",
          "condition": "ctx.score === '' || isNaN(Number(ctx.score))",
          "code": "",
          "actions": [
            { "targetId": "M14", "action": "show",    "actionArgs": "" },
            { "targetId": "M14", "action": "setText", "actionArgs": "Enter a numeric score (0–100)." },
            { "targetId": "M11", "action": "hide",    "actionArgs": "" }
          ],
          "children": []
        },

        {
          "type": "elseif",
          "condition": "Number(ctx.score) < 0 || Number(ctx.score) > 100",
          "code": "",
          "actions": [
            { "targetId": "M14", "action": "show",    "actionArgs": "" },
            { "targetId": "M14", "action": "setText", "actionArgs": "Score must be between 0 and 100." },
            { "targetId": "M11", "action": "hide",    "actionArgs": "" }
          ],
          "children": []
        },

        {
          "type": "elseif",
          "condition": "Number(ctx.score) < Number(vars.passMark)",
          "code": "DB.insert('grades',{name:ctx.name,score:Number(ctx.score),grade:'F',date:new Date().toLocaleDateString('en-US')}); EventBus.emit('gradeAdded',{value:ctx.name+' scored F ('+ctx.score+'/100).'});",
          "actions": [
            { "targetId": "M11", "action": "show",    "actionArgs": "" },
            { "targetId": "M14", "action": "hide",    "actionArgs": "" },
            { "targetId": "M12", "action": "setHTML", "actionArgs": "<span style=\"font-size:80px;font-weight:900;color:#ef4444;line-height:1\">F</span>" },
            { "targetId": "M13", "action": "setText", "actionArgs": "FAIL — Score is below the pass mark." },
            { "targetId": "",    "action": "log",     "actionArgs": "Grade F assigned via Logic elseif — vars.passMark threshold" }
          ],
          "children": []
        },

        {
          "type": "elseif",
          "condition": "Number(ctx.score) < 90",
          "code": "DB.insert('grades',{name:ctx.name,score:Number(ctx.score),grade:'B',date:new Date().toLocaleDateString('en-US')}); EventBus.emit('gradeAdded',{value:ctx.name+' scored B ('+ctx.score+'/100).'});",
          "actions": [
            { "targetId": "M11", "action": "show",    "actionArgs": "" },
            { "targetId": "M14", "action": "hide",    "actionArgs": "" },
            { "targetId": "M12", "action": "setHTML", "actionArgs": "<span style=\"font-size:80px;font-weight:900;color:#f59e0b;line-height:1\">B</span>" },
            { "targetId": "M13", "action": "setText", "actionArgs": "PASS — Good work." },
            { "targetId": "",    "action": "log",     "actionArgs": "Grade B assigned via Logic elseif" }
          ],
          "children": []
        },

        {
          "type": "else",
          "condition": "",
          "code": "DB.insert('grades',{name:ctx.name,score:Number(ctx.score),grade:'A',date:new Date().toLocaleDateString('en-US')}); EventBus.emit('gradeAdded',{value:ctx.name+' scored A ('+ctx.score+'/100).'});",
          "actions": [
            { "targetId": "M11", "action": "show",    "actionArgs": "" },
            { "targetId": "M14", "action": "hide",    "actionArgs": "" },
            { "targetId": "M12", "action": "setHTML", "actionArgs": "<span style=\"font-size:80px;font-weight:900;color:#22c55e;line-height:1\">A</span>" },
            { "targetId": "M13", "action": "setText", "actionArgs": "EXCELLENT — Top score!" },
            { "targetId": "",    "action": "log",     "actionArgs": "Grade A assigned via Logic else" }
          ],
          "children": []
        },

        {
          "type": "loop",
          "collection": "grades",
          "query": "",
          "itemVar": "g",
          "code": "if(ctx._index===ctx._total-1){var _el=document.querySelector('[data-mce-id=M16]'); if(_el)_el.textContent=ctx._total+' grade'+(ctx._total===1?'':'s')+' in this session.';}",
          "actions": [],
          "children": []
        }

      ]
    }
  },

  "dbCollections": [
    {
      "name": "grades",
      "seed": [
        { "name": "Alice",  "score": 92, "grade": "A", "date": "1/1/2026" },
        { "name": "Bob",    "score": 75, "grade": "B", "date": "1/2/2026" },
        { "name": "Carol",  "score": 45, "grade": "F", "date": "1/3/2026" }
      ]
    }
  ],

