        "width": "100%",
        "padding": "10px 14px",
        "background": "#0d0d1a",
        "border": "1px solid #2e2e4e",
        "borderRadius": "6px",
        "color": "#e2e8f0",
        "fontSize": "14px",
        "marginBottom": "12px",
