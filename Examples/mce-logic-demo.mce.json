    "M7": {
      "id": "M7", "label": "grade_desc", "tag": "p",
      "text": "Enter a name and score, click Run Logic. The Logic chain on the Run button exercises: IF / ELSEIF / ELSE (three validation guards + three grade branches) · vars.passMark in a condition · DB.insert() and EventBus.emit() in block code · a LOOP block that always runs after the chain and counts the grades collection · show / hide / setHTML / setText / log actions · and a wire on the Last Graded label that responds to the gradeAdded event emitted by the code.",
      "parentId": "M5", "children": [],
      "css": {
        "color": "#64748b",
        "fontSize": "14px",
        "lineHeight": "1.8",
        "margin": "0 0 32px 0"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M8": {
      "id": "M8", "label": "name_input", "tag": "input",
      "text": "", "parentId": "M5", "children": [],
