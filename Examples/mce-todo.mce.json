{
  "version": "1.0.0",
  "project": { "name": "Todo List — DB + Loop + pipe trigger" },
  "_nextId": 12,
  "runtimeStyle": "ocean",
  "rootOrder": ["M1"],

  "events": {
    "load":  { "name": "load",  "payload": "{}" },
    "added": { "name": "added", "payload": "{}" }
  },

  "pipes": {
    "loadTodos": {
      "name": "loadTodos",
      "method": "GET",
      "collection": "todos",
      "endpoint": "/api/db/todos",
      "delay": 0,
      "live": false
    }
  },

  "views": {},

  "loops": {
    "todoLoop": {
      "name": "todoLoop",
      "pipeName": "loadTodos",
      "targetId": "M8",
      "template": "<div style=\"display:flex;align-items:center;gap:12px;padding:12px 16px;background:#0d0d1a;border:1px solid #1e1e3e;border-radius:8px;margin-bottom:8px\"><span style=\"font-size:16px\">{{done}}</span><span style=\"color:#e2e8f0;font-size:14px;flex:1\">{{text}}</span><span style=\"font-size:10px;color:#334155\">{{ts}}</span></div>"
    }
  },

  "vars": {},
  "logic": {},

  "dbCollections": [
    {
      "name": "todos",
      "isArray": true,
      "seed": [
        { "text": "Build something with MCEngine", "done": "✓", "ts": "today" },
        { "text": "Try the Logic panel",           "done": "○", "ts": "today" },
        { "text": "Export your project as HTML",   "done": "○", "ts": "today" }
      ]
    }
  ],

  "machines": {
    "M1": {
      "id": "M1", "name": "app", "tag": "section",
      "text": "", "parentId": "", "children": ["M2","M3","M4","M7","M8"],
      "css": {
        "display": "flex", "flexDirection": "column", "gap": "20px",
        "padding": "60px 40px", "maxWidth": "560px", "margin": "0 auto",
        "fontFamily": "system-ui, sans-serif", "minHeight": "100vh"
      },
      "attrs": {},
      "wires": [
        { "eventName": "load",  "targetId": "", "action": "pipeOut", "actionArgs": "loadTodos" },
        { "eventName": "added", "targetId": "", "action": "pipeOut", "actionArgs": "loadTodos" }
      ],
      "viewBinding": null
    },

    "M2": {
      "id": "M2", "name": "title", "tag": "h1",
      "text": "Todo List",
      "parentId": "M1", "children": [],
      "css": { "color": "#e2e8f0", "fontSize": "30px", "fontWeight": "900", "margin": "0", "letterSpacing": "-0.5px" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M3": {
      "id": "M3", "name": "hint", "tag": "p",
      "text": "The Load button emits \"load\" → pipeOut loadTodos → GET todos collection → todoLoop renders each row from the seed data. Add inserts into the in-session DB then emits \"added\" which triggers the same chain to refresh.",
      "parentId": "M1", "children": [],
      "css": { "color": "#64748b", "fontSize": "13px", "lineHeight": "1.75", "margin": "0" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M4": {
      "id": "M4", "name": "input_row", "tag": "div",
      "text": "", "parentId": "M1", "children": ["M5","M6","M10"],
      "css": { "display": "flex", "gap": "10px" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M5": {
      "id": "M5", "name": "todo_input", "tag": "input",
      "text": "", "parentId": "M4", "children": [],
      "css": {
        "flex": "1", "padding": "10px 14px",
        "background": "#0d0d1a", "border": "1px solid #2e2e4e", "borderRadius": "8px",
        "color": "#e2e8f0", "fontSize": "14px", "outline": "none", "fontFamily": "inherit"
      },
      "attrs": { "type": "text", "placeholder": "What needs doing?" },
      "wires": [], "viewBinding": null
    },

    "M6": {
      "id": "M6", "name": "add_btn", "tag": "button",
      "text": "Add",
      "parentId": "M4", "children": [],
      "css": {
        "padding": "10px 22px", "background": "#a78bfa", "color": "#000",
        "fontWeight": "700", "fontSize": "14px", "border": "none",
        "borderRadius": "8px", "cursor": "pointer", "whiteSpace": "nowrap"
      },
      "attrs": {
        "onclick": "var _i=document.querySelector('[data-mce-id=\"M5\"]');var t=_i?_i.value.trim():'';if(!t)return;window.DB.insert('todos',{text:t,done:'○',ts:new Date().toLocaleTimeString()});_i.value='';window.EventBus.emit('added',{});"
      },
      "wires": [], "viewBinding": null
    },

    "M10": {
      "id": "M10", "name": "load_btn", "tag": "button",
      "text": "Load",
      "parentId": "M4", "children": [],
      "css": {
        "padding": "10px 16px", "background": "transparent", "color": "#64748b",
        "border": "1px solid #2e2e4e", "borderRadius": "8px", "cursor": "pointer",
        "fontSize": "14px", "whiteSpace": "nowrap"
      },
      "attrs": {},
      "emitOnClick": "load",
      "wires": [], "viewBinding": null
    },

    "M7": {
      "id": "M7", "name": "empty_state", "tag": "p",
      "text": "← click Load to fetch the seeded todos",
      "parentId": "M1", "children": [],
      "css": { "color": "#334155", "fontSize": "12px", "fontStyle": "italic", "margin": "0" },
      "attrs": {},
      "wires": [
        { "eventName": "load",  "targetId": "", "action": "hide", "actionArgs": "" },
        { "eventName": "added", "targetId": "", "action": "hide", "actionArgs": "" }
      ],
      "viewBinding": null
    },

    "M8": {
      "id": "M8", "name": "todo_list", "tag": "div",
      "text": "", "parentId": "M1", "children": [],
      "css": { "display": "flex", "flexDirection": "column" },
      "attrs": {}, "wires": [], "viewBinding": null
    }
  }
}
