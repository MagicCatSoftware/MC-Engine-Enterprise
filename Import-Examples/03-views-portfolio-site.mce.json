    "M19": {
      "id": "M19", "name": "detail_page", "tag": "div",
      "text": "", "parentId": "M1", "children": ["M20", "M21", "M22"],
      "css": { "display": "flex", "flexDirection": "column", "gap": "16px", "padding": "48px 24px", "boxSizing": "border-box", "width": "100%" },
      "attrs": {}, "wires": [], "viewBinding": "detail"
    },

    "M20": {
