    "M9": {
      "id": "M9", "name": "home_body", "tag": "p",
      "text": "Each machine has an optional viewBinding — set it to a view name and the machine is hidden until that view is active. Navigation fires the navigate wire action, which calls ViewSystem.navigate() and updates the URL with ?view=name.",
      "parentId": "M7", "children": [],
      "css": { "color": "#aaa", "fontSize": "14px", "lineHeight": "1.75", "margin": "0" },
      "attrs": {}, "wires": [], "viewBinding": null
