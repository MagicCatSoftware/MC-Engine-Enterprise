      "parentId": "M11", "children": [],
      "css": { "color": "#555", "fontSize": "12px", "lineHeight": "1.6", "margin": "0", "fontFamily": "monospace" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M15": {
      "id": "M15", "name": "contact_page", "tag": "div",
      "text": "", "parentId": "M1", "children": ["M16", "M17", "M18"],
      "css": { "display": "flex", "flexDirection": "column", "gap": "20px", "padding": "48px 24px", "boxSizing": "border-box", "width": "100%" },
      "attrs": {}, "wires": [], "viewBinding": "contact"
    },

