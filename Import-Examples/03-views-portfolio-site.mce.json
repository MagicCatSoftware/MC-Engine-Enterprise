      "parentId": "M1", "children": [],
      "css": { "color": "#555", "fontSize": "10px", "fontFamily": "monospace", "padding": "6px 24px", "borderBottom": "1px solid #333", "boxSizing": "border-box", "width": "100%" },
      "attrs": {},
      "wires": [
        { "eventName": "goHome",     "targetId": "", "action": "setText", "actionArgs": "current view: home" },
        { "eventName": "goProjects", "targetId": "", "action": "setText", "actionArgs": "current view: work" },
        { "eventName": "goContact",  "targetId": "", "action": "setText", "actionArgs": "current view: contact" }
      ],
      "viewBinding": null
    },

    "M7": {
      "id": "M7", "name": "home_page", "tag": "div",
      "text": "", "parentId": "M1", "children": ["M8", "M9", "M10"],
      "css": { "display": "flex", "flexDirection": "column", "gap": "20px", "padding": "48px 24px", "boxSizing": "border-box", "width": "100%" },
      "attrs": {}, "wires": [], "viewBinding": "home"
    },

    "M8": {
      "id": "M8", "name": "home_heading", "tag": "h1",
      "text": "A portfolio built from five moving parts",
      "parentId": "M7", "children": [],
      "css": { "color": "#fff", "fontSize": "28px", "fontWeight": "900", "margin": "0", "letterSpacing": "-0.5px", "lineHeight": "1.2" },
      "attrs": {}, "wires": [], "viewBinding": null
