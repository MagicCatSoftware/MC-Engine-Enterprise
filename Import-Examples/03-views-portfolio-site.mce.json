{
  "version": "1.0.0",
  "project": { "name": "MCEngine — Views: Portfolio Site" },
  "_nextId": 23,
  "rootOrder": ["M1"],

  "events": {
    "goHome":     { "name": "goHome",     "payload": "{} — navigate to the home view" },
    "goProjects": { "name": "goProjects", "payload": "{} — navigate to the projects view, also re-fetches getProjects" },
    "goContact":  { "name": "goContact",  "payload": "{} — navigate to the contact view" },
    "view:detail": { "name": "view:detail", "payload": "{ _id } — auto-emitted by ViewSystem.navigate() when a project card is clicked" }
  },

  "pipes": {
    "getProjects": {
      "name": "getProjects",
      "method": "GET",
      "collection": "projects",
      "endpoint": "/api/db/projects",
      "delay": 150,
      "live": false,
      "description": "Feeds the projectsList loop on the Projects view"
    }
  },

  "views": {
    "home":     { "name": "home" },
    "work":     { "name": "work" },
    "contact":  { "name": "contact" },
    "detail":   { "name": "detail" }
  },

  "vars": {}, "logic": {}, "templates": {},

  "loops": {
    "projectsList": {
      "name": "projectsList",
      "pipeName": "getProjects",
      "targetId": "M13",
      "dataField": "",
      "clickEvent": "",
      "clickView": "detail",
      "clickValueField": "title",
      "description": "One card per project — clicking a card navigates to the detail view with { _id } as params",
      "template": "<div style=\"cursor:pointer;padding:16px;border:1px solid #fff;border-radius:8px\"><div style=\"color:#fff;font-size:16px;font-weight:700\">{{title}}</div><div style=\"color:#aaa;font-size:13px;margin-top:6px;line-height:1.5\">{{blurb}}</div></div>"
    }
  },

  "dbCollections": [
    {
      "name": "projects",
      "isArray": true,
      "seed": [
        { "title": "Nebula UI Kit",   "blurb": "A dark, accessible component library shipped as drop-in machines." },
        { "title": "Orbit CMS",       "blurb": "Headless content editing backed by MCEngine's live pipe system." },
        { "title": "Pulse Analytics", "blurb": "Realtime dashboards built entirely from views, loops, and pipes." }
      ]
    }
  ],

  "machines": {
    "M1": {
      "id": "M1", "name": "app", "tag": "section",
      "text": "", "parentId": "", "children": ["M2", "M6", "M7", "M11", "M15", "M19"],
      "css": {
        "display": "flex", "flexDirection": "column", "gap": "0px",
        "maxWidth": "640px", "width": "100%", "margin": "0 auto",
        "fontFamily": "system-ui, sans-serif", "background": "#000",
        "minHeight": "100vh", "boxSizing": "border-box"
      },
      "attrs": {},
      "wires": [
        { "eventName": "goHome",     "targetId": "", "action": "navigate", "actionArgs": "home" },
        { "eventName": "goProjects", "targetId": "", "action": "navigate", "actionArgs": "work" },
        { "eventName": "goProjects", "targetId": "", "action": "pipeOut",  "actionArgs": "getProjects" },
        { "eventName": "goContact",  "targetId": "", "action": "navigate", "actionArgs": "contact" }
      ],
      "viewBinding": null
    },

    "M2": {
      "id": "M2", "name": "nav", "tag": "nav",
      "text": "", "parentId": "M1", "children": ["M3", "M4", "M5"],
      "css": { "display": "flex", "alignItems": "center", "gap": "4px", "padding": "16px 24px", "borderBottom": "1px solid #fff", "boxSizing": "border-box", "width": "100%" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M3": {
      "id": "M3", "name": "nav_home", "tag": "button",
      "text": "Home",
      "parentId": "M2", "children": [],
      "css": { "padding": "7px 16px", "background": "transparent", "color": "#fff", "border": "1px solid #fff", "borderRadius": "5px", "fontSize": "12px", "fontWeight": "700", "cursor": "pointer", "fontFamily": "inherit" },
      "attrs": {}, "emitOnClick": "goHome",
      "wires": [], "viewBinding": null
    },

    "M4": {
      "id": "M4", "name": "nav_projects", "tag": "button",
      "text": "Projects",
      "parentId": "M2", "children": [],
      "css": { "padding": "7px 16px", "background": "transparent", "color": "#fff", "border": "1px solid #fff", "borderRadius": "5px", "fontSize": "12px", "fontWeight": "700", "cursor": "pointer", "fontFamily": "inherit" },
      "attrs": {}, "emitOnClick": "goProjects",
      "wires": [], "viewBinding": null
    },

    "M5": {
      "id": "M5", "name": "nav_contact", "tag": "button",
      "text": "Contact",
      "parentId": "M2", "children": [],
      "css": { "padding": "7px 16px", "background": "transparent", "color": "#fff", "border": "1px solid #fff", "borderRadius": "5px", "fontSize": "12px", "fontWeight": "700", "cursor": "pointer", "fontFamily": "inherit" },
      "attrs": {}, "emitOnClick": "goContact",
      "wires": [], "viewBinding": null
