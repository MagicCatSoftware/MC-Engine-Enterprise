{
  "version": "1.0.0",
  "project": { "name": "Adom — Feature Demo" },
  "_nextId": 53,
  "runtimeStyle": "ocean",
  "rootOrder": ["M1"],

  "events": {
    "goAbout":       { "name": "goAbout",       "payload": "{}" },
    "goWork":        { "name": "goWork",         "payload": "{}" },
    "goContact":     { "name": "goContact",      "payload": "{}" },
    "typed":         { "name": "typed",          "payload": "{ value } — emitted on every keystroke in the demo input" },
    "noteSaved":     { "name": "noteSaved",      "payload": "{ value } — transferred from input, then piped to POST" },
    "selectProject": { "name": "selectProject",  "payload": "{ value, title, type, year, description } — full project doc on click" }
  },

  "pipes": {
    "getProjects": {
      "name": "getProjects", "method": "GET", "collection": "projects",
      "endpoint": "/api/db/projects", "delay": 0, "live": false,
      "queryTemplate": "", "description": "GET pipe — fetches project cards on view:work"
    },
    "saveNote": {
      "name": "saveNote", "method": "POST", "collection": "notes",
      "endpoint": "/api/db/notes", "delay": 300, "live": false,
      "queryTemplate": "", "description": "POST pipe — saves a note, triggered by button via pipeIn wire"
    }
  },

  "views": {
    "about":   { "name": "about",   "title": "About",   "description": "Bio + live wire demo", "params": [] },
    "work":    { "name": "work",    "title": "Work",    "description": "Projects from GET pipe + loop + template", "params": [] },
    "contact": { "name": "contact", "title": "Contact", "description": "Contact links", "params": [] }
  },

  "loops": {
    "projectList": {
      "name": "projectList",
      "pipeName": "getProjects",
      "targetId": "M35",
      "dataField": "",
      "clickEvent": "selectProject",
      "clickView": "",
      "clickValueField": "title",
      "description": "Renders one projectCard template per project. Click fires selectProject event.",
      "template": "<div style=\"padding:28px 0;border-top:1px solid #fff;cursor:pointer;transition:padding-left .2s\" onmouseenter=\"this.style.paddingLeft='14px'\" onmouseleave=\"this.style.paddingLeft='0'\"><div style=\"display:flex;justify-content:space-between;margin-bottom:10px\"><span style=\"font-size:9px;font-weight:700;letter-spacing:3px;color:#fff;text-transform:uppercase\">{{type}}</span><span style=\"font-size:9px;letter-spacing:2px;color:#fff\">{{year}}</span></div><h3 style=\"font-size:26px;font-weight:900;color:#fff;margin:0 0 10px 0;letter-spacing:-0.5px\">{{title}}</h3><p style=\"font-size:13px;color:#fff;line-height:1.8;margin:0\">{{description}}</p></div>"
    }
  },

  "vars": {},
  "logic": {},

  "templates": {
    "projectCard": {
      "name": "projectCard",
      "description": "Visual card for each project — built in the Templates panel, compiled into the projectList loop",
      "rootId": "TN1",
      "machines": {
        "TN1": {
          "id": "TN1", "tag": "div", "text": "",
          "css": { "padding": "28px 0", "borderTop": "1px solid #fff", "cursor": "pointer", "transition": "padding-left .2s" },
          "attrs": { "onmouseenter": "this.style.paddingLeft='14px'", "onmouseleave": "this.style.paddingLeft='0'" },
          "children": ["TN2", "TN3", "TN4"]
        },
        "TN2": {
          "id": "TN2", "tag": "div", "text": "",
          "css": { "display": "flex", "justifyContent": "space-between", "marginBottom": "10px" },
          "attrs": {}, "children": ["TN5", "TN6"]
        },
        "TN3": {
          "id": "TN3", "tag": "h3", "text": "{{title}}",
          "css": { "fontSize": "26px", "fontWeight": "900", "color": "#fff", "margin": "0 0 10px 0", "letterSpacing": "-0.5px" },
          "attrs": {}, "children": []
        },
        "TN4": {
          "id": "TN4", "tag": "p", "text": "{{description}}",
          "css": { "fontSize": "13px", "color": "#fff", "lineHeight": "1.8", "margin": "0" },
          "attrs": {}, "children": []
        },
        "TN5": {
          "id": "TN5", "tag": "span", "text": "{{type}}",
          "css": { "fontSize": "9px", "fontWeight": "700", "letterSpacing": "3px", "color": "#fff", "textTransform": "uppercase" },
          "attrs": {}, "children": []
        },
        "TN6": {
          "id": "TN6", "tag": "span", "text": "{{year}}",
          "css": { "fontSize": "9px", "letterSpacing": "2px", "color": "#fff" },
          "attrs": {}, "children": []
        }
      }
    }
  },

  "dbCollections": [
    {
      "name": "projects",
      "isArray": true,
      "seed": [
        {
          "title": "MCEngine",
          "type": "Platform",
          "year": "2026",
