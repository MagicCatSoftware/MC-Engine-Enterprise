  "rootOrder": ["M1"],

  "events": {
    "goAbout":       { "name": "goAbout",       "payload": "" },
    "goWork":        { "name": "goWork",         "payload": "" },
    "goContact":     { "name": "goContact",      "payload": "" },
    "typed":         { "name": "typed",          "payload": "{ value } — fires on every keystroke in the demo input" },
    "noteSaved":     { "name": "noteSaved",      "payload": "{ value } — transferred from note input on button click" },
    "selectProject": { "name": "selectProject",  "payload": "{ value, title, type, year, description } — emitted on project row click" }
  },

  "pipes": {
    "getProjects": {
      "name": "getProjects",
      "method": "GET",
      "collection": "projects",
      "endpoint": "/api/db/projects",
      "delay": 0,
      "live": false,
      "queryTemplate": "",
      "description": "Fetches all projects for the work-view loop"
    }
  },

  "views": {
    "about":   { "name": "about",   "title": "About",   "description": "Profile + bio + live tech demos", "params": [] },
    "work":    { "name": "work",    "title": "Work",    "description": "Projects via GET pipe + loop",     "params": [] },
    "contact": { "name": "contact", "title": "Contact", "description": "Get in touch",                     "params": [] }
  },

  "loops": {
    "projectList": {
      "name": "projectList",
      "pipeName": "getProjects",
      "targetId": "M35",
      "dataField": "",
      "clickEvent": "selectProject",
      "clickView": "",
      "clickValueField": "title",
      "description": "Renders one row per project. Click fires selectProject with full doc as payload.",
      "template": "<div style=\"padding:24px 0;border-top:1px solid #1a1a1a;transition:padding-left .15s ease\" onmouseenter=\"this.style.paddingLeft='14px';this.style.borderTopColor='#333'\" onmouseleave=\"this.style.paddingLeft='0';this.style.borderTopColor='#1a1a1a'\"><div style=\"display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px\"><span style=\"font-size:9px;font-weight:700;letter-spacing:3px;color:#555;text-transform:uppercase\">{{type}}</span><span style=\"font-size:9px;letter-spacing:1px;color:#444\">{{year}}</span></div><h3 style=\"font-size:20px;font-weight:900;color:#fff;margin:0 0 8px 0;letter-spacing:-0.3px\">{{title}}</h3><p style=\"font-size:12px;color:#777;line-height:1.9;margin:0\">{{description}}</p></div>",
      "pageSize": 0,
      "paginationId": ""
    }
  },

  "vars": {},
  "logic": {},
  "templates": {},

  "dbCollections": [
    {
      "name": "projects",
      "isArray": true,
      "seed": [
        {
          "title": "Magic Cat Engine",
          "type": "Platform",
          "year": "2026",
          "description": "A visual IDE for assembling interactive web apps. Machines, events, pipes, loops, logic and templates — wired together in real time without leaving the browser."
