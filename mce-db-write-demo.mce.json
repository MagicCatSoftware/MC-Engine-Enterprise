{
  "version": "1.0.0",
  "project": { "name": "DB Write + Read Across Views" },
  "_nextId": 22,
  "runtimeStyle": "ocean",
  "rootOrder": ["M1"],

  "events": {
    "navWrite": { "name": "navWrite", "payload": "{}" },
    "navList":  { "name": "navList",  "payload": "{}" }
  },

  "pipes": {
    "readContacts": {
      "name": "readContacts",
      "method": "GET",
      "endpoint": "/api/showcase/contacts",
      "collection": "contacts",
      "delay": 0,
      "schema": [],
      "live": true
    }
  },

  "views": {
    "write": {
      "name": "write",
      "title": "Add Contact",
      "description": "Form view — Logic calls fetch() POST to /api/showcase/contacts, then navigates to list.",
      "params": []
    },
    "list": {
      "name": "list",
      "title": "Contact List",
      "description": "List view — view:list event triggers pipeOut readContacts, Loop renders every DB record.",
      "params": []
    }
  },

  "loops": {
    "contactsLoop": {
      "name": "contactsLoop",
      "pipeName": "readContacts",
      "targetId": "M16",
      "template": "<div style=\"background:#13131f;border:1px solid #2e2e4e;border-radius:10px;padding:18px 20px;flex:1;min-width:220px;max-width:300px\"><div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:10px\"><div style=\"font-size:15px;font-weight:700;color:#e2e8f0\">{{name}}</div><div style=\"font-size:10px;background:#1e0f3e;color:#a78bfa;padding:3px 8px;border-radius:4px;font-weight:700;text-transform:uppercase\">{{category}}</div></div><div style=\"font-size:13px;color:#64748b;margin-bottom:8px\">{{email}}</div><div style=\"font-size:11px;color:#334155\">Added {{date}}</div></div>"
    }
  },

  "vars": {},

  "logic": {
    "M11": {
      "blocks": [
        {
          "type": "if",
          "condition": "!ctx.name",
          "code": "",
          "actions": [
            { "targetId": "M12", "action": "show",    "actionArgs": "" },
            { "targetId": "M12", "action": "setText", "actionArgs": "Name is required." }
          ],
          "children": []
        },
        {
          "type": "else",
          "condition": "",
          "code": "var _n=document.querySelector('[data-mce-id=M8]'); var _e=document.querySelector('[data-mce-id=M9]'); var _c=document.querySelector('[data-mce-id=M10]'); if(_n)_n.value=''; if(_e)_e.value=''; if(_c&&_c.options)_c.selectedIndex=0; fetch('/api/showcase/contacts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:ctx.name,email:ctx.email||'—',category:ctx.category||'General',date:new Date().toLocaleDateString('en-US')})}).then(function(){ViewSystem.navigate('list',{});});",
          "actions": [
            { "targetId": "M12", "action": "show",    "actionArgs": "" },
            { "targetId": "M12", "action": "setText", "actionArgs": "Saving..." }
          ],
          "children": []
        }
      ]
    }
  },

  "dbCollections": [],

  "machines": {

    "M1": {
      "id": "M1", "label": "app", "tag": "section",
      "text": "", "parentId": "", "children": ["M2", "M5", "M13"],
      "css": {
        "display": "flex",
        "flexDirection": "column",
        "minHeight": "100vh",
        "fontFamily": "system-ui, -apple-system, sans-serif"
      },
      "attrs": {},
      "wires": [
        { "eventName": "navWrite", "targetId": "", "action": "navigate", "actionArgs": "write" },
        { "eventName": "navList",  "targetId": "", "action": "navigate", "actionArgs": "list"  }
      ],
      "viewBinding": null
    },

    "M2": {
      "id": "M2", "label": "nav_bar", "tag": "nav",
      "text": "", "parentId": "M1", "children": ["M3", "M4"],
      "css": {
        "display": "flex",
        "alignItems": "center",
        "gap": "8px",
        "padding": "14px 40px",
        "background": "#0d0d1a",
        "borderBottom": "1px solid #1e1e3e"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M3": {
      "id": "M3", "label": "btn_write", "tag": "button",
      "text": "+ Add Contact",
      "parentId": "M2", "children": [],
      "css": {
        "padding": "6px 16px",
        "background": "#a78bfa",
        "color": "#000",
        "fontWeight": "700",
        "fontSize": "13px",
        "border": "none",
        "borderRadius": "4px",
        "cursor": "pointer"
      },
      "attrs": {},
      "emitOnClick": "navWrite",
      "wires": [],
      "viewBinding": null
    },

    "M4": {
      "id": "M4", "label": "btn_list", "tag": "button",
      "text": "View Contacts",
      "parentId": "M2", "children": [],
      "css": {
        "padding": "6px 16px",
        "background": "transparent",
        "color": "#a78bfa",
        "border": "1px solid #3a3a5c",
        "borderRadius": "4px",
        "cursor": "pointer",
        "fontSize": "13px"
      },
      "attrs": {},
      "emitOnClick": "navList",
      "wires": [],
      "viewBinding": null
    },

    "M5": {
      "id": "M5", "label": "write_view", "tag": "section",
      "text": "", "parentId": "M1",
      "children": ["M6", "M7", "M8", "M9", "M10", "M11", "M12"],
      "css": { "padding": "52px 40px", "maxWidth": "540px" },
      "attrs": {},
      "wires": [],
      "viewBinding": "write"
    },

    "M6": {
      "id": "M6", "label": "write_title", "tag": "h1",
      "text": "Add a Contact",
      "parentId": "M5", "children": [],
      "css": {
        "color": "#e2e8f0",
        "fontSize": "32px",
        "fontWeight": "900",
        "letterSpacing": "-1px",
        "margin": "0 0 10px 0"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M7": {
      "id": "M7", "label": "write_desc", "tag": "p",
      "text": "Fill in the form and click Save. The Logic block POSTs to /api/showcase/contacts (MongoDB), then navigates to the List view where a pipeOut wire GETs the fresh list and the Loop renders every record — including the one you just saved.",
      "parentId": "M5", "children": [],
      "css": {
        "color": "#64748b",
        "fontSize": "14px",
        "lineHeight": "1.75",
        "margin": "0 0 32px 0"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M8": {
      "id": "M8", "label": "name_input", "tag": "input",
      "text": "", "parentId": "M5", "children": [],
      "css": {
        "display": "block",
        "width": "100%",
        "padding": "10px 14px",
        "background": "#0d0d1a",
        "border": "1px solid #2e2e4e",
        "borderRadius": "6px",
        "color": "#e2e8f0",
        "fontSize": "14px",
        "marginBottom": "14px",
        "outline": "none",
        "fontFamily": "inherit",
        "boxSizing": "border-box"
      },
      "attrs": { "type": "text", "placeholder": "Full name (required)" },
      "wires": [],
      "viewBinding": null
    },

    "M9": {
      "id": "M9", "label": "email_input", "tag": "input",
      "text": "", "parentId": "M5", "children": [],
      "css": {
        "display": "block",
        "width": "100%",
        "padding": "10px 14px",
        "background": "#0d0d1a",
        "border": "1px solid #2e2e4e",
        "borderRadius": "6px",
        "color": "#e2e8f0",
        "fontSize": "14px",
        "marginBottom": "14px",
        "outline": "none",
        "fontFamily": "inherit",
        "boxSizing": "border-box"
      },
      "attrs": { "type": "email", "placeholder": "Email address" },
      "wires": [],
      "viewBinding": null
    },

    "M10": {
      "id": "M10", "label": "cat_select", "tag": "select",
      "text": "", "parentId": "M5",
      "children": ["M17", "M18", "M19", "M20"],
      "css": {
        "display": "block",
        "width": "100%",
        "padding": "10px 14px",
        "background": "#0d0d1a",
        "border": "1px solid #2e2e4e",
        "borderRadius": "6px",
        "color": "#e2e8f0",
        "fontSize": "14px",
        "marginBottom": "24px",
        "outline": "none",
        "cursor": "pointer",
        "boxSizing": "border-box"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M11": {
      "id": "M11", "label": "submit_btn", "tag": "button",
      "text": "Save Contact",
      "parentId": "M5", "children": [],
      "css": {
        "padding": "11px 28px",
        "background": "#a78bfa",
        "color": "#000000",
        "fontWeight": "700",
        "fontSize": "14px",
        "border": "none",
        "borderRadius": "6px",
        "cursor": "pointer",
        "display": "inline-block"
      },
      "attrs": {
        "onclick": "var _n=document.querySelector('[data-mce-id=M8]'); var _e=document.querySelector('[data-mce-id=M9]'); var _c=document.querySelector('[data-mce-id=M10]'); var ctx={name:(_n?_n.value:'').trim(),email:(_e?_e.value:'').trim(),category:(_c?_c.value:'General')||'General'}; if(typeof LogicSystem!=='undefined')LogicSystem.run('M11',ctx); else if(typeof MachineSystem!=='undefined')MachineSystem.executeLogic('M11',ctx);"
      },
      "wires": [],
      "viewBinding": null
    },

    "M12": {
      "id": "M12", "label": "status_text", "tag": "p",
      "text": "",
      "parentId": "M5", "children": [],
      "css": {
        "display": "none",
        "marginTop": "14px",
        "padding": "10px 14px",
        "background": "#1a1a2e",
        "border": "1px solid #3a3a5c",
        "borderRadius": "6px",
        "color": "#a78bfa",
        "fontSize": "13px"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M13": {
      "id": "M13", "label": "list_view", "tag": "section",
      "text": "", "parentId": "M1",
      "children": ["M14", "M15", "M16"],
      "css": { "padding": "52px 40px" },
      "attrs": {},
      "wires": [
        { "eventName": "view:list", "targetId": "", "action": "pipeOut", "actionArgs": "readContacts" }
      ],
      "viewBinding": "list"
    },

    "M14": {
      "id": "M14", "label": "list_title", "tag": "h1",
      "text": "Contacts",
      "parentId": "M13", "children": [],
      "css": {
        "color": "#e2e8f0",
        "fontSize": "32px",
        "fontWeight": "900",
        "letterSpacing": "-1px",
        "margin": "0 0 10px 0"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M15": {
      "id": "M15", "label": "list_note", "tag": "p",
      "text": "Every contact saved from the Add view persists in MongoDB and appears here on refresh. The view:list event triggers pipeOut readContacts — the Loop re-reads the server and renders fresh cards.",
      "parentId": "M13", "children": [],
      "css": {
        "color": "#64748b",
        "fontSize": "14px",
        "lineHeight": "1.75",
