{
  "version": "1.0.0",
  "project": { "name": "MCEngine — Event System Demo" },
  "_nextId": 19,
  "runtimeStyle": "dark",
  "rootOrder": ["M1"],

  "events": {
    "typed": {
      "name": "typed",
      "payload": "{ value } — emitted on every keystroke via emitOnInput"
    },
    "submitted": {
      "name": "submitted",
      "payload": "{ value } — emitted by Submit button via transferOnClick"
    },
    "cleared": {
      "name": "cleared",
      "payload": "{ value } — emitted by Clear button via transferOnClick"
    }
  },

  "pipes": {},
  "views": {},
  "loops": {},
  "vars": {},
  "logic": {},
  "dbCollections": [],
  "templates": {},

  "machines": {
    "M1": {
      "id": "M1", "name": "app", "tag": "section",
      "text": "", "parentId": "", "children": ["M2","M3","M4","M8","M13","M17","M18"],
      "css": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "28px",
        "padding": "40px 24px",
        "maxWidth": "640px",
        "width": "100%",
        "margin": "0 auto",
        "fontFamily": "system-ui, sans-serif",
        "background": "#000",
        "minHeight": "100vh",
        "boxSizing": "border-box",
        "overflowX": "hidden"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M2": {
      "id": "M2", "name": "title", "tag": "h1",
      "text": "MCEngine — Event System",
      "parentId": "M1", "children": [],
      "css": {
        "color": "#fff",
        "fontSize": "28px",
        "fontWeight": "900",
        "margin": "0",
        "letterSpacing": "-0.5px",
        "borderBottom": "1px solid #fff",
        "paddingBottom": "16px"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M3": {
      "id": "M3", "name": "subtitle", "tag": "p",
      "text": "Events are named signals. Any machine can emit them; any machine can listen. One emit fires all matching wires simultaneously — fan-out by design.",
      "parentId": "M1", "children": [],
      "css": { "color": "#aaa", "fontSize": "13px", "lineHeight": "1.7", "margin": "0" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M4": {
      "id": "M4", "name": "input_row", "tag": "div",
      "text": "", "parentId": "M1", "children": ["M5","M6","M7"],
      "css": { "display": "flex", "gap": "10px", "alignItems": "stretch", "width": "100%", "boxSizing": "border-box" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M5": {
      "id": "M5", "name": "text_input", "tag": "input",
