        "fontSize": "13px",
        "fontWeight": "700",
        "cursor": "pointer",
        "fontFamily": "inherit"
      },
      "attrs": {},
      "transferOnClick": { "fromId": "M5", "eventName": "submitted" },
      "wires": [], "viewBinding": null
