        "border": "1px solid #fff",
        "borderRadius": "6px",
        "color": "#fff",
        "fontSize": "15px",
        "outline": "none",
        "fontFamily": "inherit",
        "boxSizing": "border-box"
      },
      "attrs": { "type": "text", "placeholder": "Type something…", "autocomplete": "off" },
      "emitOnInput": "typed",
      "wires": [], "viewBinding": null
    },

    "M6": {
      "id": "M6", "name": "submit_btn", "tag": "button",
