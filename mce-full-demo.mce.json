{
  "version": "1.0.0",
  "project": { "name": "MCEngine — Full Feature Demo" },
  "_nextId": 31,
  "rootOrder": ["M1"],

  "events": {
    "goBoard":          { "name": "goBoard",          "payload": "{} — navigate to Board view"                        },
    "goAdd":            { "name": "goAdd",             "payload": "{} — navigate to Add Task view"                    },
    "goAnalytics":      { "name": "goAnalytics",       "payload": "{} — navigate to Analytics view"                   },
    "fetchTriggered":   { "name": "fetchTriggered",    "payload": "{} — fires pipeOut getTasks via M1 wire"           },
    "taskSelected":     { "name": "taskSelected",      "payload": "full task record — {title, priority, status, assignee}" },
    "taskTyped":        { "name": "taskTyped",         "payload": "{ value } — emitted on every keystroke"            },
    "taskAdded":        { "name": "taskAdded",         "payload": "{ value } — fires pipeIn addTask via M1 wire"      },
    "analyzeRequested": { "name": "analyzeRequested",  "payload": "{} — triggers runLogic on M28"                    },
    "analyzeResult":    { "name": "analyzeResult",     "payload": "{ value, high, done } — emitted from logic code"   }
  },

  "views": {
    "board":     { "name": "board"     },
    "add":       { "name": "add"       },
    "analytics": { "name": "analytics" }
  },

  "pipes": {
    "getTasks": {
      "name": "getTasks",
      "method": "GET",
      "collection": "tasks",
      "endpoint": "/api/db/tasks",
      "delay": 0,
      "live": false,
      "description": "Reads all task records from the tasks collection"
    },
    "addTask": {
      "name": "addTask",
      "method": "POST",
      "collection": "tasks",
      "endpoint": "/api/db/tasks",
      "delay": 0,
      "live": false,
      "description": "Creates a new task — body is the event payload {value}"
    }
  },

  "loops": {
    "taskList": {
      "name": "taskList",
      "pipeName": "getTasks",
      "targetId": "M13",
      "dataField": "",
      "clickEvent": "taskSelected",
      "clickView": "",
      "clickValueField": "",
      "description": "One card per task — clicking fires taskSelected with the full record",
      "template": "<div style=\"display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border:1px solid #fff;border-radius:8px;background:#000;gap:12px;cursor:pointer;box-sizing:border-box\"><div style=\"flex:1;min-width:0\"><div style=\"color:#fff;font-size:14px;font-weight:700\">{{value}}</div><div style=\"color:#555;font-size:11px;margin-top:4px;font-family:monospace\">{{assignee}}</div></div><div style=\"display:flex;gap:8px;align-items:center;flex-shrink:0\"><span style=\"font-size:10px;padding:2px 10px;border:1px solid #fff;border-radius:20px;color:#fff;white-space:nowrap\">{{priority}}</span><span style=\"font-size:10px;color:#555;white-space:nowrap\">{{status}}</span></div></div>"
    }
  },

  "templates": {
    "taskCard": {
      "name": "taskCard",
      "rootId": "TN1",
      "machines": {
        "TN1": {
          "id": "TN1", "tag": "div", "text": "", "children": ["TN2","TN3"],
          "css": { "display": "flex", "alignItems": "center", "justifyContent": "space-between", "padding": "12px 16px", "border": "1px solid #fff", "borderRadius": "8px", "background": "#000", "gap": "12px", "cursor": "pointer", "width": "100%", "boxSizing": "border-box" },
          "attrs": {}
        },
        "TN2": {
          "id": "TN2", "tag": "div", "text": "{{value}}", "children": [],
          "css": { "color": "#fff", "fontSize": "14px", "fontWeight": "700", "flex": "1" },
          "attrs": {}
        },
        "TN3": {
          "id": "TN3", "tag": "span", "text": "{{priority}}", "children": [],
          "css": { "color": "#fff", "fontSize": "10px", "padding": "2px 10px", "border": "1px solid #fff", "borderRadius": "20px", "flexShrink": "0" },
          "attrs": {}
        }
      }
    }
  },

  "vars": {},

  "logic": {
    "M28": {
      "blocks": [
        {
          "type": "if",
          "condition": "true",
          "actions": [],
          "code": "var t=DB.find('tasks',{});var h=t.filter(function(x){return x.priority==='High';}).length;var d=t.filter(function(x){return x.status==='Done';}).length;EventBus.emit('analyzeResult',{value:String(t.length)+' total tasks',high:String(h)+' high priority',done:String(d)+' completed'});",
          "children": []
        }
      ]
    }
  },

  "dbCollections": [
    {
      "name": "tasks",
      "isArray": true,
      "seed": [
        { "value": "Build the API",      "priority": "High",   "status": "In Progress", "assignee": "Adom" },
        { "value": "Design the UI",      "priority": "High",   "status": "Done",        "assignee": "Adom" },
        { "value": "Write tests",        "priority": "Medium", "status": "Todo",        "assignee": "Adom" },
        { "value": "Deploy to prod",     "priority": "High",   "status": "Todo",        "assignee": "Adom" },
        { "value": "Write the docs",     "priority": "Low",    "status": "Todo",        "assignee": "Adom" }
      ]
    }
  ],

