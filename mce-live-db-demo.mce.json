        "margin": "0",
        "paddingBottom": "10px",
        "borderBottom": "1px solid #fff"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M14": {
      "id": "M14", "name": "post_endpoint", "tag": "div",
      "text": "POST /api/db/entries  ·  live: true  ·  body: event payload",
      "parentId": "M12", "children": [],
      "css": { "color": "#555", "fontSize": "11px", "fontFamily": "monospace" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M15": {
      "id": "M15", "name": "input_row", "tag": "div",
      "text": "", "parentId": "M12", "children": ["M16","M17"],
      "css": {
        "display": "flex",
        "gap": "10px",
        "alignItems": "stretch",
