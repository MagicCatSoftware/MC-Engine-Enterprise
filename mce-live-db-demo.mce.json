      "css": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "12px",
        "border": "1px solid #fff",
        "borderRadius": "8px",
        "padding": "18px",
        "width": "100%",
        "boxSizing": "border-box"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M13": {
      "id": "M13", "name": "post_label", "tag": "p",
      "text": "POST — write to live DB",
      "parentId": "M12", "children": [],
      "css": {
        "color": "#fff",
        "fontSize": "11px",
        "fontWeight": "700",
        "letterSpacing": "1px",
