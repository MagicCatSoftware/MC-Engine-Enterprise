      "id": "M7", "name": "get_section", "tag": "div",
      "text": "", "parentId": "M1", "children": ["M8","M9","M10","M11"],
      "css": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "12px",
        "border": "1px solid #fff",
        "borderRadius": "8px",
        "padding": "18px",
        "width": "100%",
        "boxSizing": "border-box"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M8": {
      "id": "M8", "name": "get_label", "tag": "p",
      "text": "GET — read from live DB",
      "parentId": "M7", "children": [],
      "css": {
        "color": "#fff",
        "fontSize": "11px",
        "fontWeight": "700",
        "letterSpacing": "1px",
        "textTransform": "uppercase",
        "margin": "0",
        "paddingBottom": "10px",
        "borderBottom": "1px solid #fff"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M9": {
      "id": "M9", "name": "get_endpoint", "tag": "div",
      "text": "GET /api/db/entries  ·  live: true",
      "parentId": "M7", "children": [],
      "css": { "color": "#555", "fontSize": "11px", "fontFamily": "monospace" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M10": {
      "id": "M10", "name": "refresh_btn", "tag": "button",
      "text": "Refresh from DB",
      "parentId": "M7", "children": [],
      "css": {
        "padding": "10px 18px",
        "background": "#fff",
        "color": "#000",
        "border": "1px solid #fff",
        "borderRadius": "6px",
        "fontSize": "13px",
        "fontWeight": "700",
        "cursor": "pointer",
        "fontFamily": "inherit",
        "alignSelf": "flex-start"
      },
      "attrs": {},
      "emitOnClick": "fetchTriggered",
      "wires": [], "viewBinding": null
    },

    "M11": {
      "id": "M11", "name": "entries_list", "tag": "div",
