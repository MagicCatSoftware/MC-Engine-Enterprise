        "boxSizing": "border-box"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M16": {
      "id": "M16", "name": "entry_input", "tag": "input",
      "text": "", "parentId": "M15", "children": [],
      "css": {
        "flex": "1",
        "padding": "10px 14px",
        "background": "#000",
        "border": "1px solid #fff",
        "borderRadius": "6px",
        "color": "#fff",
        "fontSize": "14px",
        "outline": "none",
        "fontFamily": "inherit",
        "boxSizing": "border-box"
      },
      "attrs": { "type": "text", "placeholder": "Type an entry…", "autocomplete": "off" },
      "emitOnInput": "entryTyped",
      "wires": [], "viewBinding": null
    },

    "M17": {
      "id": "M17", "name": "add_btn", "tag": "button",
      "text": "Add to DB",
      "parentId": "M15", "children": [],
      "css": {
        "padding": "10px 18px",
        "background": "#fff",
        "color": "#000",
        "border": "1px solid #fff",
        "borderRadius": "6px",
        "fontSize": "13px",
        "fontWeight": "700",
        "cursor": "pointer",
        "fontFamily": "inherit",
        "whiteSpace": "nowrap"
      },
      "attrs": {},
      "transferOnClick": { "fromId": "M16", "eventName": "entryAdded" },
      "wires": [], "viewBinding": null
    },

    "M18": {
      "id": "M18", "name": "post_status", "tag": "div",
      "text": "POST status — add an entry to see the real write fire",
      "parentId": "M12", "children": [],
      "css": {
        "color": "#555",
        "fontSize": "12px",
        "fontFamily": "monospace",
        "padding": "8px 12px",
        "border": "1px solid #333",
        "borderRadius": "6px"
      },
      "attrs": {},
      "wires": [
        { "eventName": "entryAdded", "targetId": "", "action": "setText", "actionArgs": "POST fired → wrote {value: \"{{value}}\"} to /api/db/entries" }
      ],
      "viewBinding": null
    },

    "M19": {
      "id": "M19", "name": "pipe_log", "tag": "div",
      "text": "pipe log — trigger GET or POST to see it here",
      "parentId": "M1", "children": [],
      "css": {
        "color": "#555",
        "fontSize": "11px",
        "fontFamily": "monospace",
        "paddingTop": "16px",
        "borderTop": "1px solid #fff"
      },
      "attrs": {},
      "wires": [
        { "eventName": "fetchTriggered", "targetId": "", "action": "setText", "actionArgs": "last: GET /api/db/entries (live: true)" },
        { "eventName": "entryAdded",     "targetId": "", "action": "setText", "actionArgs": "last: POST /api/db/entries (live: true) — body: {value: \"{{value}}\"}" }
      ],
      "viewBinding": null
    }
