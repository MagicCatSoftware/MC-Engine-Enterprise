{
  "version": "1.0.0",
  "project": { "name": "MCEngine — Logic System Demo" },
  "_nextId": 20,
  "rootOrder": ["M1"],

  "events": {
    "calcRequested": {
      "name": "calcRequested",
      "payload": "{ value } — number string from the input, passed as ctx to M5's logic"
    },
    "loopRequested": {
      "name": "loopRequested",
      "payload": "{} — triggers M12's loop block to iterate the items collection"
    },
    "resultReady": {
      "name": "resultReady",
      "payload": "{ value, label } — emitted from code blocks, received by M9 and M19"
    }
  },

  "pipes": {},
  "views": {},
  "vars": {},
  "templates": {},
  "loops": {},

  "dbCollections": [
    {
      "name": "items",
      "isArray": true,
      "seed": [
        { "label": "Alpha",   "score": 92 },
        { "label": "Beta",    "score": 45 },
        { "label": "Gamma",   "score": 78 },
        { "label": "Delta",   "score": 61 },
        { "label": "Epsilon", "score": 33 }
      ]
    }
  ],

  "logic": {
    "M5": {
      "blocks": [
        {
          "type": "if",
          "condition": "parseInt(ctx.value) >= 100",
          "actions": [
            { "targetId": "M8", "action": "setText", "actionArgs": "BIG — {{value}} is ≥ 100" }
          ],
          "code": "EventBus.emit('resultReady', { value: ctx.value, label: 'BIG' });",
          "children": []
        },
        {
          "type": "elseif",
          "condition": "parseInt(ctx.value) >= 50",
          "actions": [
            { "targetId": "M8", "action": "setText", "actionArgs": "MEDIUM — {{value}} is 50–99" }
          ],
          "code": "EventBus.emit('resultReady', { value: ctx.value, label: 'MEDIUM' });",
          "children": []
        },
        {
          "type": "elseif",
          "condition": "parseInt(ctx.value) > 0",
          "actions": [
            { "targetId": "M8", "action": "setText", "actionArgs": "SMALL — {{value}} is 1–49" }
          ],
          "code": "EventBus.emit('resultReady', { value: ctx.value, label: 'SMALL' });",
          "children": []
        },
        {
          "type": "else",
          "condition": "",
          "actions": [
            { "targetId": "M8", "action": "setText", "actionArgs": "Enter a number above 0" }
          ],
          "code": "",
          "children": []
        }
      ]
    },
    "M12": {
      "blocks": [
        {
          "type": "loop",
          "collection": "items",
          "query": "",
          "itemVar": "item",
          "actions": [],
          "code": "EventBus.emit('resultReady', { value: ctx.item.label + ': ' + ctx.item.score, label: ctx.item.score >= 60 ? 'PASS' : 'FAIL' });",
          "children": []
        }
      ]
    }
  },

  "machines": {
    "M1": {
      "id": "M1", "name": "app", "tag": "section",
      "text": "", "parentId": "", "children": ["M2","M3","M4","M10","M15","M19"],
      "css": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "28px",
        "padding": "40px 24px",
        "maxWidth": "640px",
        "width": "100%",
        "margin": "0 auto",
        "fontFamily": "system-ui, sans-serif",
        "background": "#000",
        "minHeight": "100vh",
        "boxSizing": "border-box"
      },
      "attrs": {},
      "wires": [
        { "eventName": "loopRequested", "targetId": "", "action": "runLogic", "actionArgs": "M12" }
      ],
      "viewBinding": null
    },

    "M2": {
      "id": "M2", "name": "title", "tag": "h1",
      "text": "MCEngine — Logic System",
      "parentId": "M1", "children": [],
      "css": {
        "color": "#fff",
        "fontSize": "28px",
        "fontWeight": "900",
        "margin": "0",
        "letterSpacing": "-0.5px",
        "borderBottom": "1px solid #fff",
        "paddingBottom": "16px"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M3": {
      "id": "M3", "name": "subtitle", "tag": "p",
      "text": "Logic blocks run JavaScript conditionals (if/elseif/else), iterate DB collections (loop), and execute arbitrary code. They are triggered by the runLogic wire action with the event payload passed as ctx.",
      "parentId": "M1", "children": [],
      "css": { "color": "#aaa", "fontSize": "13px", "lineHeight": "1.7", "margin": "0" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

