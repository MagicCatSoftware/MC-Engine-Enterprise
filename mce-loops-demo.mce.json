{
  "version": "1.0.0",
  "project": { "name": "MCEngine — Loop System Demo" },
  "_nextId": 15,
  "rootOrder": ["M1"],

  "events": {
    "bookSelected": {
      "name": "bookSelected",
      "payload": "Full book record — { title, author, year, genre, description, status }"
    }
  },

  "pipes": {
    "getBooks": {
      "name": "getBooks",
      "method": "GET",
      "collection": "books",
      "endpoint": "/api/db/books",
      "delay": 0,
      "live": false,
      "description": "Reads all books from the books collection"
    }
  },

  "loops": {
    "bookList": {
      "name": "bookList",
      "pipeName": "getBooks",
      "targetId": "M7",
      "dataField": "",
      "clickEvent": "bookSelected",
      "clickView": "",
      "clickValueField": "",
      "description": "One card per book — clicking fires bookSelected with the full record as payload",
      "template": "<div style=\"padding:12px 14px;border:1px solid #fff;border-radius:6px;cursor:pointer;background:#000\"><div style=\"color:#fff;font-size:14px;font-weight:700\">{{title}}</div><div style=\"color:#aaa;font-size:12px;margin-top:4px\">{{author}} &middot; {{year}}</div><div style=\"color:#555;font-size:11px;margin-top:6px\">{{genre}}</div></div>"
    }
  },

  "views": {},
  "vars": {},
  "logic": {},
  "templates": {},

  "dbCollections": [
    {
      "name": "books",
      "isArray": true,
      "seed": [
        { "title": "The Pragmatic Programmer", "author": "Andrew Hunt",    "year": 1999, "genre": "Software Engineering", "description": "A journey toward mastery of programming craft covering DRY principles, code generation, and delivering software on time.", "status": "Classic"     },
        { "title": "Clean Code",                "author": "Robert Martin",  "year": 2008, "genre": "Software Engineering", "description": "A handbook of agile craftsmanship showing how to write readable, maintainable code that other engineers actually enjoy.",  "status": "Essential"   },
        { "title": "You Don't Know JS",         "author": "Kyle Simpson",   "year": 2015, "genre": "JavaScript",           "description": "A deep dive into the core mechanisms of JavaScript — types, scopes, closures, async, and the parts most devs skip.",     "status": "Open Source" },
        { "title": "The Design of Everyday Things", "author": "Don Norman", "year": 1988, "genre": "Design",               "description": "Why some products feel natural and others frustrate — the principles behind good human-centred design.",                  "status": "Timeless"    },
        { "title": "Hackers & Painters",        "author": "Paul Graham",    "year": 2004, "genre": "Essays",               "description": "Big ideas from the computer age — programming as creative work, what makes startups succeed, and building things that last.", "status": "Inspiring"   }
      ]
    }
  ],

