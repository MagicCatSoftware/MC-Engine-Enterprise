{
  "version": "1.0.0",
  "project": { "name": "Photo Gallery" },
  "_nextId": 29,
  "runtimeStyle": "ocean",
  "rootOrder": ["M1"],

  "events": {
    "selectPhoto":              { "name": "selectPhoto",              "payload": "{ value:_id, _id, url, name, caption } — photo card clicked in grid" },
    "goGallery":                { "name": "goGallery",                "payload": "— navigate back to the gallery grid" },
    "goUpload":                 { "name": "goUpload",                 "payload": "— open the Add Photo form" },
    "doCreate":                 { "name": "doCreate",                 "payload": "— Add Photo save button clicked" },
    "doUpdate":                 { "name": "doUpdate",                 "payload": "{ value:_id } — Save Changes button clicked on detail view" },
    "doDelete":                 { "name": "doDelete",                 "payload": "{ value:_id } — Delete button clicked on detail view" },
    "urlPreview":               { "name": "urlPreview",               "payload": "{ value:url } — URL field typed in upload form; used to preview the image" },
    "fileSelected":              { "name": "fileSelected",              "payload": "— image file chosen; triggers uploadFile pipe" },
    "pipe:createPhoto:written": { "name": "pipe:createPhoto:written", "payload": "{ pipe, data } — POST succeeded; navigate away and refresh grid" },
    "pipe:updatePhoto:written": { "name": "pipe:updatePhoto:written", "payload": "{ pipe, data } — PATCH succeeded; navigate away and refresh grid" },
    "pipe:deletePhoto:written": { "name": "pipe:deletePhoto:written", "payload": "{ pipe, data } — DELETE succeeded; navigate away and refresh grid" }
  },

  "pipes": {
    "getPhotos": {
      "name": "getPhotos",
      "method": "GET",
      "endpoint": "/api/db/Photos",
      "delay": 0,
      "live": true,
      "description": "Fetch all photo records — feeds the photoGrid loop."
    },
    "getOnePhoto": {
      "name": "getOnePhoto",
      "method": "GET",
      "endpoint": "/api/db/Photos",
      "urlTemplate": "/api/db/Photos/{{payload:value}}",
      "delay": 0,
      "live": true,
      "description": "Fetch one photo by _id — triggered on selectPhoto to populate the detail view."
    },
    "createPhoto": {
      "name": "createPhoto",
      "method": "POST",
      "endpoint": "/api/db/Photos",
      "bodyTemplate": {
        "url":     "{{machine:M23}}",
        "name":    "{{machine:M25}}",
        "caption": "{{machine:M26}}"
      },
      "delay": 0,
      "live": true,
      "description": "Create a new photo — reads url/name/caption directly from the upload form input machines"
    },
    "updatePhoto": {
      "name": "updatePhoto",
      "method": "PUT",
      "endpoint": "/api/db/Photos",
      "urlTemplate": "/api/db/Photos/{{payload:value}}",
      "bodyTemplate": {
        "url":     "{{machine:M13}}",
        "name":    "{{machine:M14}}",
        "caption": "{{machine:M15}}"
      },
      "delay": 0,
      "live": true,
      "description": "Update a photo — payload.value is the _id; reads edited field values from detail-view inputs"
    },
    "deletePhoto": {
      "name": "deletePhoto",
      "method": "DELETE",
      "endpoint": "/api/db/Photos",
      "urlTemplate": "/api/db/Photos/{{payload:value}}",
      "delay": 0,
      "live": true,
      "description": "Delete a photo by _id — payload.value must be the _id string"
    },
    "uploadFile": {
      "name": "uploadFile",
      "method": "UPLOAD",
      "endpoint": "/api/files/upload",
      "sourceField": "M28",
      "live": true,
      "description": "Upload an image file from M28 — result url auto-fills M23 and M24 via pipeBindings"
    }
  },

  "views": {
    "gallery": { "name": "gallery", "title": "Gallery",    "description": "Default view — photo grid with Add button",                     "params": [] },
    "detail":  { "name": "detail",  "title": "Photo",      "description": "View, edit or delete one photo; populated via getOnePhoto pipe", "params": ["_id"] },
    "upload":  { "name": "upload",  "title": "Add Photo",  "description": "Form for creating a new photo record",                          "params": [] }
  },

  "loops": {
    "photoGrid": {
      "name": "photoGrid",
      "pipeName": "getPhotos",
      "targetId": "M6",
      "dataField": "",
      "clickEvent": "selectPhoto",
      "clickView": "detail",
      "clickValueField": "_id",
      "description": "One card per photo — clicking emits selectPhoto (value=_id) and navigates to detail view",
      "template": "<div style=\"overflow:hidden;border-radius:10px;background:#111827;border:1px solid #1e1e3e;cursor:pointer;transition:transform .15s\" onmouseover=\"this.style.transform='scale(1.02)'\" onmouseout=\"this.style.transform=''\"><img src=\"{{url}}\" style=\"width:100%;aspect-ratio:1;object-fit:cover;display:block\" loading=\"lazy\"/><div style=\"padding:8px 10px\"><p style=\"margin:0;font-size:12px;font-weight:600;color:#e2e8f0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis\">{{name}}</p><p style=\"margin:3px 0 0;font-size:11px;color:#475569;white-space:nowrap;overflow:hidden;text-overflow:ellipsis\">{{caption}}</p></div></div>"
    }
  },

  "vars": {},

  "machines": {

    "M1": {
      "id": "M1", "name": "app", "tag": "section",
      "text": "", "parentId": "", "children": ["M2", "M7", "M20"],
      "css": { "minHeight": "100vh", "background": "#080812", "fontFamily": "system-ui, sans-serif" },
      "attrs": {},
      "viewBinding": null,
      "wires": [
        { "eventName": "view:gallery",              "targetId": "", "action": "pipeOut",  "actionArgs": "getPhotos"    },
        { "eventName": "goGallery",                 "targetId": "", "action": "navigate", "actionArgs": "gallery"      },
        { "eventName": "goUpload",                  "targetId": "", "action": "navigate", "actionArgs": "upload"       },
        { "eventName": "fileSelected",              "targetId": "", "action": "pipeExec", "actionArgs": "uploadFile"    },
        { "eventName": "selectPhoto",               "targetId": "", "action": "pipeExec", "actionArgs": "getOnePhoto"   },
        { "eventName": "doCreate",                  "targetId": "", "action": "pipeExec", "actionArgs": "createPhoto"  },
        { "eventName": "doUpdate",                  "targetId": "", "action": "pipeExec", "actionArgs": "updatePhoto"  },
        { "eventName": "doDelete",                  "targetId": "", "action": "pipeExec", "actionArgs": "deletePhoto"  },
        { "eventName": "pipe:createPhoto:written",  "targetId": "", "action": "navigate", "actionArgs": "gallery"      },
        { "eventName": "pipe:createPhoto:written",  "targetId": "", "action": "pipeOut",  "actionArgs": "getPhotos"    },
        { "eventName": "pipe:updatePhoto:written",  "targetId": "", "action": "navigate", "actionArgs": "gallery"      },
        { "eventName": "pipe:updatePhoto:written",  "targetId": "", "action": "pipeOut",  "actionArgs": "getPhotos"    },
        { "eventName": "pipe:deletePhoto:written",  "targetId": "", "action": "navigate", "actionArgs": "gallery"      },
        { "eventName": "pipe:deletePhoto:written",  "targetId": "", "action": "pipeOut",  "actionArgs": "getPhotos"    }
      ],
      "varWires": [],
      "pipeBindings": []
    },

    "M2": {
      "id": "M2", "name": "gallery_view", "tag": "div",
      "text": "", "parentId": "M1", "children": ["M3", "M6"],
      "css": { "padding": "48px 40px", "maxWidth": "1200px", "margin": "0 auto", "display": "flex", "flexDirection": "column", "gap": "0" },
      "attrs": { "data-mce-display": "flex" },
      "viewBinding": "gallery",
      "wires": [], "pipeBindings": []
    },

    "M3": {
      "id": "M3", "name": "gallery_header", "tag": "div",
