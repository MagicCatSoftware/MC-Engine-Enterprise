        "fontSize": "12px",
        "color": "#475569",
        "fontStyle": "italic"
      },
      "attrs": {},
      "wires": [
        {
          "eventName": "loadPortfolio",
          "targetId": "",
          "action": "setText",
          "actionArgs": "Fetching from /api/showcase/portfolio..."
        }
      ],
      "viewBinding": null
    },

    "M7": {
      "id": "M7",
