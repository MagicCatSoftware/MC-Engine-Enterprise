      "css": {
        "display": "flex",
        "alignItems": "center",
        "gap": "20px"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M5": {
      "id": "M5",
      "label": "fetch_btn",
      "tag": "button",
      "text": "Load Portfolio",
      "parentId": "M4",
      "children": [],
      "css": {
        "padding": "11px 26px",
        "background": "#a78bfa",
        "color": "#000000",
        "fontWeight": "700",
        "fontSize": "14px",
        "border": "none",
        "borderRadius": "6px",
        "cursor": "pointer",
        "letterSpacing": "0.01em"
      },
      "attrs": {},
      "emitOnClick": "loadPortfolio",
      "wires": [
        {
          "eventName": "loadPortfolio",
          "targetId": "",
          "action": "pipeOut",
          "actionArgs": "fetchPortfolio"
        }
      ],
      "viewBinding": null
