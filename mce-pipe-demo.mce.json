{
  "version": "1.0.0",
  "project": { "name": "Pipe Demo — Live MongoDB" },
  "_nextId": 10,
  "runtimeStyle": "ocean",
  "rootOrder": ["M1"],

  "events": {
    "loadPortfolio": {
      "name": "loadPortfolio",
      "payload": "{}"
    }
  },

  "pipes": {
    "fetchPortfolio": {
      "name": "fetchPortfolio",
      "method": "GET",
      "endpoint": "/api/showcase/portfolio",
      "collection": "portfolio",
      "delay": 300,
      "schema": [],
      "live": true
    }
  },

  "views": {},

  "loops": {
    "portfolioLoop": {
      "pipeName": "fetchPortfolio",
      "targetId": "M7",
      "template": "<div style=\"background:#13131f;border:1px solid #2e2e4e;border-radius:10px;padding:20px 22px;min-width:220px;max-width:300px;flex:1;display:flex;flex-direction:column;gap:10px\"><div style=\"font-size:10px;color:#a78bfa;font-weight:700;text-transform:uppercase;letter-spacing:1.2px\">{{tech}}</div><div style=\"color:#e2e8f0;font-size:16px;font-weight:700;line-height:1.3\">{{title}}</div><div style=\"color:#64748b;font-size:13px;line-height:1.6\">{{description}}</div><div style=\"font-size:11px;color:#334155;margin-top:auto\">{{year}}</div></div>"
    }
  },

  "vars": {},

  "logic": {},

  "dbCollections": [
    {
      "name": "portfolio",
      "seed": [
        { "title": "Magic Cat Engine",     "description": "Visual no-code IDE for building interactive, database-driven profile pages.", "tech": "Node.js · MongoDB · Express", "year": "2026" },
        { "title": "Weather Dashboard",    "description": "Real-time weather data visualization with animated charts and 7-day forecasts.", "tech": "React · D3.js", "year": "2025" },
        { "title": "Task Manager Pro",     "description": "Collaborative task management with live sync and offline-first architecture.", "tech": "Vue.js · Socket.io", "year": "2025" },
        { "title": "AI Portfolio Builder", "description": "GPT-powered portfolio page generator with custom theme support and export.", "tech": "Python · FastAPI · OpenAI", "year": "2024" }
      ]
    }
  ],

  "machines": {
    "M1": {
      "id": "M1",
      "label": "app",
      "tag": "section",
      "text": "",
      "parentId": "",
      "children": ["M2", "M3", "M4", "M7"],
      "css": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "28px",
        "padding": "48px 40px",
        "maxWidth": "960px",
        "margin": "0 auto",
        "fontFamily": "system-ui, -apple-system, sans-serif",
        "minHeight": "100vh"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M2": {
      "id": "M2",
      "label": "title",
      "tag": "h1",
      "text": "Pipe Demo — Live MongoDB",
      "parentId": "M1",
      "children": [],
      "css": {
        "color": "#e2e8f0",
        "fontSize": "34px",
        "fontWeight": "900",
        "letterSpacing": "-1px",
        "margin": "0",
        "lineHeight": "1.1"
      },
      "attrs": {},
      "wires": [],
      "viewBinding": null
    },

    "M3": {
      "id": "M3",
      "label": "description",
      "tag": "p",
      "text": "Click the button to fire the loadPortfolio event. A Wire on the button calls PipeSystem.fetch(\"fetchPortfolio\") → GET /api/showcase/portfolio → the Loop renders each MongoDB record as a card below.",
      "parentId": "M1",
      "children": [],
      "css": {
        "color": "#64748b",
        "fontSize": "14px",
        "lineHeight": "1.75",
        "margin": "0",
        "maxWidth": "580px"
      },
      "attrs": {},
