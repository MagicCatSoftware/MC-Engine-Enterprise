{
  "version": "1.0.0",
  "project": { "name": "MCEngine — Pipe System Demo" },
  "_nextId": 16,
  "rootOrder": ["M1"],

  "events": {
    "noteTyped": {
      "name": "noteTyped",
      "payload": "{ value } — emitted on every keystroke via emitOnInput"
    },
    "noteSaved": {
      "name": "noteSaved",
      "payload": "{ value } — emitted by Save button via transferOnClick"
    },
    "noteFetchRequested": {
      "name": "noteFetchRequested",
      "payload": "{} — emitted by Fetch button via emitOnClick"
    }
  },

  "pipes": {
    "getNotes": {
      "name": "getNotes",
      "method": "GET",
      "collection": "notes",
      "endpoint": "/api/db/notes",
      "delay": 0,
      "live": false,
      "description": "Reads all records from the notes collection"
    },
    "saveNote": {
      "name": "saveNote",
      "method": "POST",
      "collection": "notes",
      "endpoint": "/api/db/notes",
      "delay": 0,
      "description": "Creates a new note in the notes collection — body is the event payload"
    }
  },

  "views": {},
  "vars": {},
  "logic": {},
  "templates": {},

  "loops": {
    "notesList": {
      "name": "notesList",
      "pipeName": "getNotes",
      "targetId": "M8",
      "dataField": "",
      "clickEvent": "",
      "clickView": "",
      "clickValueField": "",
      "description": "One card per note returned by getNotes",
      "template": "<div style=\"padding:12px 16px;border:1px solid #fff;border-radius:6px;background:#000;font-family:monospace\"><div style=\"color:#fff;font-size:14px\">{{value}}</div><div style=\"color:#555;font-size:10px;margin-top:6px\">{{_createdAt}}</div></div>"
    }
  },

  "dbCollections": [
    {
      "name": "notes",
      "isArray": true,
      "seed": [
        { "value": "Build the pipe demo" },
        { "value": "Ship MCEngine v1" },
        { "value": "Write more examples" }
      ]
    }
  ],

  "machines": {
    "M1": {
      "id": "M1", "name": "app", "tag": "section",
      "text": "", "parentId": "", "children": ["M2","M3","M4","M9","M15"],
      "css": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "28px",
        "padding": "40px 24px",
        "maxWidth": "640px",
        "width": "100%",
        "margin": "0 auto",
        "fontFamily": "system-ui, sans-serif",
        "background": "#000",
        "minHeight": "100vh",
        "boxSizing": "border-box"
      },
      "attrs": {},
      "wires": [
        { "eventName": "noteSaved",         "targetId": "", "action": "pipeIn",  "actionArgs": "saveNote"  },
        { "eventName": "noteFetchRequested", "targetId": "", "action": "pipeOut", "actionArgs": "getNotes" }
      ],
      "viewBinding": null
    },

    "M2": {
      "id": "M2", "name": "title", "tag": "h1",
      "text": "MCEngine — Pipe System",
      "parentId": "M1", "children": [],
      "css": {
        "color": "#fff",
        "fontSize": "28px",
        "fontWeight": "900",
        "margin": "0",
        "letterSpacing": "-0.5px",
        "borderBottom": "1px solid #fff",
        "paddingBottom": "16px"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M3": {
      "id": "M3", "name": "subtitle", "tag": "p",
      "text": "Pipes connect machines to your database. A GET pipe reads data and feeds it to a loop. A POST pipe writes data using the event payload as the request body.",
      "parentId": "M1", "children": [],
      "css": { "color": "#aaa", "fontSize": "13px", "lineHeight": "1.7", "margin": "0" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M4": {
      "id": "M4", "name": "get_section", "tag": "div",
      "text": "", "parentId": "M1", "children": ["M5","M6","M8"],
      "css": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "12px",
        "border": "1px solid #fff",
        "borderRadius": "8px",
        "padding": "18px",
        "width": "100%",
        "boxSizing": "border-box"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M5": {
      "id": "M5", "name": "get_label", "tag": "p",
      "text": "GET pipe — reads from DB on fetch",
      "parentId": "M4", "children": [],
      "css": {
        "color": "#fff",
        "fontSize": "11px",
        "fontWeight": "700",
        "letterSpacing": "1px",
        "textTransform": "uppercase",
        "margin": "0",
        "paddingBottom": "10px",
        "borderBottom": "1px solid #fff"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M6": {
      "id": "M6", "name": "fetch_row", "tag": "div",
      "text": "", "parentId": "M4", "children": ["M7"],
      "css": { "display": "flex", "gap": "10px", "alignItems": "center" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M7": {
      "id": "M7", "name": "fetch_btn", "tag": "button",
      "text": "Fetch Notes",
      "parentId": "M6", "children": [],
      "css": {
        "padding": "10px 20px",
        "background": "#fff",
        "color": "#000",
        "border": "1px solid #fff",
        "borderRadius": "6px",
        "fontSize": "13px",
        "fontWeight": "700",
        "cursor": "pointer",
        "fontFamily": "inherit"
      },
      "attrs": {},
      "emitOnClick": "noteFetchRequested",
      "wires": [], "viewBinding": null
    },

    "M8": {
      "id": "M8", "name": "notes_list", "tag": "div",
      "text": "", "parentId": "M4", "children": [],
      "css": { "display": "flex", "flexDirection": "column", "gap": "8px" },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M9": {
      "id": "M9", "name": "post_section", "tag": "div",
      "text": "", "parentId": "M1", "children": ["M10","M11","M14"],
      "css": {
        "display": "flex",
        "flexDirection": "column",
        "gap": "12px",
        "border": "1px solid #fff",
        "borderRadius": "8px",
        "padding": "18px",
        "width": "100%",
        "boxSizing": "border-box"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M10": {
      "id": "M10", "name": "post_label", "tag": "p",
      "text": "POST pipe — writes to DB using event payload",
      "parentId": "M9", "children": [],
      "css": {
        "color": "#fff",
        "fontSize": "11px",
        "fontWeight": "700",
        "letterSpacing": "1px",
        "textTransform": "uppercase",
        "margin": "0",
        "paddingBottom": "10px",
        "borderBottom": "1px solid #fff"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M11": {
      "id": "M11", "name": "input_row", "tag": "div",
      "text": "", "parentId": "M9", "children": ["M12","M13"],
      "css": {
        "display": "flex",
        "gap": "10px",
        "alignItems": "stretch",
        "width": "100%",
        "boxSizing": "border-box"
      },
      "attrs": {}, "wires": [], "viewBinding": null
    },

    "M12": {
      "id": "M12", "name": "note_input", "tag": "input",
      "text": "", "parentId": "M11", "children": [],
      "css": {
        "flex": "1",
        "padding": "10px 14px",
        "background": "#000",
        "border": "1px solid #fff",
        "borderRadius": "6px",
        "color": "#fff",
        "fontSize": "14px",
        "outline": "none",
        "fontFamily": "inherit",
        "boxSizing": "border-box"
      },
      "attrs": { "type": "text", "placeholder": "Type a note…", "autocomplete": "off" },
      "emitOnInput": "noteTyped",
      "wires": [], "viewBinding": null
    },

    "M13": {
      "id": "M13", "name": "save_btn", "tag": "button",
      "text": "Save Note",
      "parentId": "M11", "children": [],
      "css": {
        "padding": "10px 20px",
        "background": "#fff",
        "color": "#000",
        "border": "1px solid #fff",
        "borderRadius": "6px",
        "fontSize": "13px",
        "fontWeight": "700",
        "cursor": "pointer",
        "fontFamily": "inherit",
        "whiteSpace": "nowrap"
      },
      "attrs": {},
      "transferOnClick": { "fromId": "M12", "eventName": "noteSaved" },
      "wires": [], "viewBinding": null
    },

    "M14": {
      "id": "M14", "name": "post_status", "tag": "div",
      "text": "POST status — save a note to see it fire",
      "parentId": "M9", "children": [],
      "css": {
        "color": "#555",
        "fontSize": "12px",
        "fontFamily": "monospace",
        "padding": "8px 12px",
        "border": "1px solid #333",
        "borderRadius": "6px"
      },
      "attrs": {},
      "wires": [
        { "eventName": "noteSaved", "targetId": "", "action": "setText", "actionArgs": "POST fired → saved: \"{{value}}\"" }
      ],
      "viewBinding": null
    },

    "M15": {
      "id": "M15", "name": "pipe_log", "tag": "div",
      "text": "pipe log — trigger either pipe to see it here",
      "parentId": "M1", "children": [],
      "css": {
        "color": "#555",
        "fontSize": "11px",
        "fontFamily": "monospace",
        "paddingTop": "16px",
        "borderTop": "1px solid #fff"
      },
      "attrs": {},
      "wires": [
        { "eventName": "noteSaved",         "targetId": "", "action": "setText", "actionArgs": "last pipe: POST saveNote — body: {value: \"{{value}}\"}" },
        { "eventName": "noteFetchRequested", "targetId": "", "action": "setText", "actionArgs": "last pipe: GET getNotes — reading notes collection" }
      ],
      "viewBinding": null
    }
  }
}
