{
  "version": "1.0.0",
  "project": { "name": "MCEngine Feature Showcase" },
  "_nextId": 50,
  "runtimeStyle": "ocean",
  "rootOrder": ["M1"],

  "events": {
    "appReady":          { "name": "appReady",          "payload": "{ version }" },
    "navHome":           { "name": "navHome",            "payload": "{}" },
    "navUsers":          { "name": "navUsers",           "payload": "{}" },
    "navSettings":       { "name": "navSettings",        "payload": "{}" },
    "navAbout":          { "name": "navAbout",           "payload": "{}" },
    "counterUpdated":    { "name": "counterUpdated",     "payload": "{ value }" },
    "counterReset":      { "name": "counterReset",       "payload": "{}" },
    "counterMaxReached": { "name": "counterMaxReached",  "payload": "{ value }" },
    "searchChanged":     { "name": "searchChanged",      "payload": "{ value }  — emitted by search input oninput" },
    "userSelected":      { "name": "userSelected",       "payload": "{ id, name, email, role }" },
    "userNameSelected":  { "name": "userNameSelected",   "payload": "{ value }  — name string" },
    "userEmailSelected": { "name": "userEmailSelected",  "payload": "{ value }  — email string" },
    "userRoleSelected":  { "name": "userRoleSelected",   "payload": "{ value }  — role string" },
    "userDetailClosed":  { "name": "userDetailClosed",   "payload": "{}" },
    "usersFetched":        { "name": "usersFetched",        "payload": "{ value }  — count of users" },
    "fetchUsersClicked":   { "name": "fetchUsersClicked",   "payload": "{}" },
    "loadProductsClicked": { "name": "loadProductsClicked", "payload": "{}" },
    "settingsSaved":       { "name": "settingsSaved",       "payload": "{ value }  — saved username" }
  },

  "pipes": {
    "readUsers": {
      "name": "readUsers",
      "method": "GET",
      "endpoint": "/api/users",
      "collection": "users",
      "delay": 400,
      "schema": [],
      "live": false
    },
    "createUser": {
      "name": "createUser",
      "method": "POST",
      "endpoint": "/api/users",
      "collection": "users",
      "delay": 500,
      "schema": [
        { "key": "name",  "type": "text" },
        { "key": "email", "type": "text" },
        { "key": "role",  "type": "text" }
      ],
      "live": false
    },
    "readProducts": {
      "name": "readProducts",
      "method": "GET",
      "endpoint": "/api/products",
      "collection": "products",
      "delay": 300,
      "schema": [],
      "live": false
    },
    "saveSettings": {
      "name": "saveSettings",
      "method": "POST",
      "endpoint": "/api/settings",
      "collection": "settings",
      "delay": 600,
      "schema": [
        { "key": "username", "type": "text" },
        { "key": "email",    "type": "text" },
        { "key": "theme",    "type": "text" }
      ],
      "live": false
    }
  },

  "views": {
    "home":     { "name": "home",     "title": "Home",     "description": "Counter demo, event log, and product loop",     "params": [] },
    "users":    { "name": "users",    "title": "Users",    "description": "Search + fetch users, click card for detail",   "params": ["userId"] },
    "settings": { "name": "settings", "title": "Settings", "description": "Form with validation logic and settings pipe",  "params": [] },
    "about":    { "name": "about",    "title": "About",    "description": "Project info and feature reference",            "params": [] }
  },

  "loops": {
    "userLoop": {
      "name": "userLoop",
      "pipeName": "readUsers",
      "targetId": "M23",
      "description": "Each user card from readUsers GET pipe. Click card emits userSelected + sub-events.",
      "template": "<div style=\"padding:10px;margin-bottom:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:6px;cursor:pointer\" onclick=\"EventBus.emit('userSelected',{id:'{{id}}',name:'{{name}}',email:'{{email}}',role:'{{role}}'}); EventBus.emit('userNameSelected',{value:'{{name}}'}); EventBus.emit('userEmailSelected',{value:'{{email}}'}); EventBus.emit('userRoleSelected',{value:'{{role}}'})\">\n  <div style=\"font-weight:bold;color:#7dd3fc\">{{name}}</div>\n  <div style=\"font-size:11px;color:#94a3b8\">{{email}}</div>\n  <div style=\"display:flex;gap:8px;align-items:center;margin-top:5px\">\n    <span style=\"font-size:10px;padding:1px 7px;background:rgba(124,58,237,0.25);color:#c4b5fd;border-radius:10px\">{{role}}</span>\n    <span style=\"font-size:10px;color:#475569\">#{{_index}} of {{_total}}</span>\n  </div>\n</div>"
    },
    "productLoop": {
      "name": "productLoop",
      "pipeName": "readProducts",
      "targetId": "M45",
      "description": "Each product card from readProducts GET pipe.",
      "template": "<div style=\"padding:10px;margin-bottom:8px;background:rgba(16,185,129,0.07);border:1px solid rgba(16,185,129,0.2);border-radius:6px\">\n  <div style=\"font-weight:bold;color:#34d399\">{{name}}</div>\n  <div style=\"font-size:12px;color:#94a3b8;margin-top:2px\">{{price | CURRENCY}} &mdash; {{category}}</div>\n  <div style=\"font-size:10px;color:#64748b;margin-top:5px\">Stock: {{stock}} &nbsp;|&nbsp; Item {{_index}} of {{_total}}</div>\n</div>"
    }
  },

  "vars": {
    "counter":        { "value": "0",     "desc": "Global counter — incremented/decremented by the Home buttons",     "public": false },
    "theme":          { "value": "ocean", "desc": "Active UI theme name",                                              "public": true  },
    "currentUser":    { "value": "Guest", "desc": "Display name of the logged-in user (updated by Settings save)",   "public": true  },
    "selectedUserId": { "value": "",      "desc": "ID of the user shown in the detail panel",                         "public": false },
    "userCount":      { "value": "5",     "desc": "Count of users in the last readUsers fetch",                       "public": false },
    "searchQuery":    { "value": "",      "desc": "Current text in the Users search box",                             "public": false }
  },

