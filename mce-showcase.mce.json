    "M37": {
      "id": "M37", "tag": "div", "name": "about_content",
      "attrs": {},
      "text": "<p style=\"margin:0 0 10px;color:#94a3b8\">This project demonstrates every major MCEngine feature in one importable JSON.</p><ul style=\"color:#64748b;font-size:12px;line-height:2;padding-left:18px\"><li><strong style=\"color:#7dd3fc\">Events</strong> — 16 named events with payloads. Nav buttons use emitOnClick to fire navHome/navUsers/etc.</li><li><strong style=\"color:#34d399\">Pipes</strong> — readUsers (GET), createUser (POST), readProducts (GET), saveSettings (POST).</li><li><strong style=\"color:#a78bfa\">Views</strong> — home, users, settings, about. View-bound machines auto-show/hide on navigate.</li><li><strong style=\"color:#f59e0b\">Loops</strong> — userLoop renders user cards; productLoop renders product cards. Both wired to GET pipes.</li><li><strong style=\"color:#38bdf8\">Vars</strong> — counter, theme, currentUser, selectedUserId, userCount, searchQuery.</li><li><strong style=\"color:#fb923c\">Logic</strong> — increment_btn: nested if/elseif/else + counterMaxReached emit. decrement_btn: floor guard. reset_btn: zero-check. save_btn: 3-rule validation chain. fetch_users_btn: DB loop then pipeOut.</li><li><strong style=\"color:#e2e8f0\">Wires</strong> — counterUpdated updates display text via {{THIS.VALUE}}. userSelected shows detail panel and populates name/email/role via three sub-events.</li></ul>",
      "children": [], "parentId": "M35",
      "wires": [], "varWires": [], "pipeBindings": [], "viewBinding": null,
      "css": {
        "line-height": "1.6", "font-size": "13px", "color": "#e2e8f0",
        "background": "#1e293b", "padding": "16px", "border-radius": "8px",
        "border": "1px solid #334155"
      },
      "dbSource": null, "emitOnInput": "", "emitOnClick": "",
      "transferOnClick": { "fromId": "", "eventName": "" },
      "inputTransform":  { "filter": "", "arg": "" },
      "outputTransform": { "filter": "", "arg": "" }
    }

  },

  "logic": {

    "M14": {
      "blocks": [
        {
          "type": "if",
          "condition": "parseInt(vars.counter) >= 10",
          "code": "Logger.warn('Increment blocked — counter already at max: ' + vars.counter);",
          "actions": [
            { "targetId": "M17", "action": "setText", "actionArgs": "Maximum (10) already reached — click Reset to continue." }
          ],
          "children": []
        },
        {
          "type": "else",
          "condition": "",
          "code": "var n = parseInt(vars.counter || '0') + 1; vars.counter = String(n); if (typeof MCE !== 'undefined') MCE.vars['counter'].value = vars.counter; if (typeof MCE_VARS !== 'undefined') MCE_VARS.counter = vars.counter; EventBus.emit('counterUpdated', { value: n });",
          "actions": [],
          "children": [
            {
              "type": "if",
              "condition": "parseInt(vars.counter) >= 10",
              "code": "EventBus.emit('counterMaxReached', { value: parseInt(vars.counter) });",
              "actions": [
                { "targetId": "M17", "action": "setText", "actionArgs": "Maximum reached! (10/10) — click Reset to continue." }
              ],
              "children": []
            },
            {
              "type": "elseif",
              "condition": "parseInt(vars.counter) >= 7",
              "code": "",
              "actions": [
                { "targetId": "M17", "action": "setText", "actionArgs": "Almost there — 3 more to reach maximum!" }
              ],
              "children": []
            },
            {
              "type": "elseif",
              "condition": "parseInt(vars.counter) >= 5",
              "code": "",
              "actions": [
                { "targetId": "M17", "action": "setText", "actionArgs": "Over halfway to maximum!" }
              ],
              "children": []
            },
            {
              "type": "else",
              "condition": "",
              "code": "",
              "actions": [
                { "targetId": "M17", "action": "setText", "actionArgs": "Keep incrementing..." }
              ],
              "children": []
            }
          ]
        }
      ]
    },

    "M15": {
      "blocks": [
        {
          "type": "if",
          "condition": "parseInt(vars.counter) <= 0",
          "code": "Logger.warn('Decrement blocked — counter already at zero');",
          "actions": [
            { "targetId": "M17", "action": "setText", "actionArgs": "Already at zero — nothing to decrement." }
          ],
          "children": []
        },
        {
          "type": "else",
          "condition": "",
          "code": "var n = Math.max(0, parseInt(vars.counter || '0') - 1); vars.counter = String(n); if (typeof MCE !== 'undefined') MCE.vars['counter'].value = vars.counter; if (typeof MCE_VARS !== 'undefined') MCE_VARS.counter = vars.counter; EventBus.emit('counterUpdated', { value: n });",
          "actions": [],
          "children": [
            {
              "type": "if",
              "condition": "parseInt(vars.counter) === 0",
              "code": "",
              "actions": [
                { "targetId": "M17", "action": "setText", "actionArgs": "Back to zero." },
                { "targetId": "M7",  "action": "hide",    "actionArgs": "" }
              ],
              "children": []
            },
            {
              "type": "else",
              "condition": "",
              "code": "",
              "actions": [
                { "targetId": "M17", "action": "setText", "actionArgs": "Decremented." }
              ],
              "children": []
            }
          ]
        }
      ]
    },

    "M16": {
      "blocks": [
        {
          "type": "if",
          "condition": "parseInt(vars.counter) === 0",
          "code": "Logger.info('Reset called but counter is already zero');",
          "actions": [
            { "targetId": "M17", "action": "setText", "actionArgs": "Counter is already at zero." }
          ],
          "children": []
        },
        {
          "type": "else",
          "condition": "",
          "code": "vars.counter = '0'; if (typeof MCE !== 'undefined') MCE.vars['counter'].value = '0'; if (typeof MCE_VARS !== 'undefined') MCE_VARS.counter = '0'; EventBus.emit('counterReset', {});",
          "actions": [
            { "targetId": "M17", "action": "setText", "actionArgs": "Counter reset to zero." },
            { "targetId": "M7",  "action": "hide",    "actionArgs": "" }
          ],
          "children": []
        }
      ]
    },

    "M22": {
      "blocks": [
        {
          "type": "if",
          "condition": "true",
          "code": "Logger.info('Scanning local DB users before API fetch...');",
          "actions": [
            { "targetId": "M23", "action": "setHTML", "actionArgs": "<p style='color:#64748b;font-size:12px;padding:8px;font-style:italic'>Fetching from API...</p>" }
          ],
          "children": []
        },
        {
          "type": "loop",
          "collection": "users",
          "query": "{}",
          "itemVar": "u",
          "condition": "",
          "code": "Logger.info('  DB user: ' + u.name + ' [' + u.role + ']');",
          "actions": [],
          "children": [
            {
              "type": "if",
              "condition": "u.role === 'admin'",
              "code": "Logger.ok('Admin found: ' + u.name);",
              "actions": [],
              "children": []
            },
            {
              "type": "elseif",
              "condition": "u.active === false",
              "code": "Logger.warn('Inactive user: ' + u.name);",
              "actions": [],
              "children": []
            },
            {
              "type": "else",
              "condition": "",
              "code": "",
              "actions": [],
              "children": []
            }
          ]
        },
        {
          "type": "if",
          "condition": "true",
          "code": "PipeSystem.fetch('readUsers'); var cnt = DB.find('users', {}).length; EventBus.emit('usersFetched', { value: cnt }); Logger.ok('readUsers pipe fired — userLoop will render ' + cnt + ' records');",
          "actions": [],
          "children": []
        }
      ]
    },

    "M33": {
      "blocks": [
        {
          "type": "if",
          "condition": "!ctx.username || ctx.username.trim() === ''",
          "code": "Logger.error('Validation failed: username is empty');",
          "actions": [
            { "targetId": "M34", "action": "show",    "actionArgs": "" },
            { "targetId": "M34", "action": "setText", "actionArgs": "Error: Username is required." }
          ],
          "children": []
        },
        {
          "type": "elseif",
          "condition": "ctx.username && ctx.username.trim().length < 3",
          "code": "Logger.warn('Validation failed: username too short');",
          "actions": [
            { "targetId": "M34", "action": "show",    "actionArgs": "" },
            { "targetId": "M34", "action": "setText", "actionArgs": "Error: Username must be at least 3 characters." }
          ],
          "children": []
        },
        {
          "type": "elseif",
          "condition": "ctx.email && ctx.email.indexOf('@') === -1",
          "code": "Logger.warn('Validation failed: invalid email');",
          "actions": [
            { "targetId": "M34", "action": "show",    "actionArgs": "" },
            { "targetId": "M34", "action": "setText", "actionArgs": "Error: Please enter a valid email address." }
          ],
          "children": []
        },
        {
          "type": "else",
          "condition": "",
          "code": "var uname = ctx.username.trim(); vars.currentUser = uname; if (typeof MCE !== 'undefined') MCE.vars['currentUser'].value = uname; if (typeof MCE_VARS !== 'undefined') MCE_VARS.currentUser = uname; PipeSystem.execute('saveSettings', { username: uname, email: ctx.email || '', theme: vars.theme || 'ocean' }); EventBus.emit('settingsSaved', { value: uname }); Logger.ok('Settings saved for: ' + uname);",
          "actions": [
            { "targetId": "M34", "action": "show",    "actionArgs": "" },
            { "targetId": "M34", "action": "setText", "actionArgs": "Settings saved successfully!" }
          ],
          "children": []
        }
      ]
    },

    "M44": {
      "blocks": [
        {
          "type": "if",
          "condition": "true",
          "code": "Logger.info('Firing readProducts pipe — productLoop will render results into M45'); PipeSystem.fetch('readProducts');",
          "actions": [
            { "targetId": "M45", "action": "setHTML", "actionArgs": "<p style='color:#64748b;font-size:12px;padding:8px;font-style:italic'>Loading products...</p>" }
          ],
          "children": []
        }
      ]
    }

  },

  "dbCollections": [
    {
      "name": "users",
