{
  "version": "1.0.0",
  "project": { "name": "Views + URL Params Demo" },
  "_nextId": 22,
  "runtimeStyle": "ocean",
  "rootOrder": ["M1"],

  "events": {
    "navHome":              { "name": "navHome",              "payload": "{}" },
    "navProjects":          { "name": "navProjects",          "payload": "{}" },
    "projectTitleSelected": { "name": "projectTitleSelected", "payload": "{ value }  — project title string" },
    "projectDescSelected":  { "name": "projectDescSelected",  "payload": "{ value }  — project description string" },
    "projectTechSelected":  { "name": "projectTechSelected",  "payload": "{ value }  — tech stack string" },
    "projectParamsSelected":{ "name": "projectParamsSelected","payload": "{ value }  — raw URL query string for display" }
  },

  "pipes": {
    "readProjects": {
      "name": "readProjects",
      "method": "GET",
      "endpoint": "/api/showcase/projects",
      "collection": "projects",
      "delay": 200,
      "schema": [],
      "live": false
    }
  },

  "views": {
    "home": {
      "name": "home",
      "title": "Home",
      "description": "Landing page. First view in the list — auto-activated on Live Preview load with no URL params.",
      "params": []
    },
    "projects": {
      "name": "projects",
      "title": "Projects",
      "description": "Project list. A wire on this section listens for view:projects → pipeOut, so the loop auto-loads when the view activates.",
      "params": []
    },
    "detail": {
      "name": "detail",
      "title": "Project Detail",
      "description": "Shows a selected project. URL becomes ?view=detail&id=X&title=...&tech=...&year=X when navigated to.",
      "params": ["id", "title", "description", "tech", "year"]
    }
  },

  "loops": {
    "projectsLoop": {
      "pipeName": "readProjects",
      "targetId": "M11",
      "template": "<div style=\"background:#13131f;border:1px solid #2e2e4e;border-radius:10px;padding:20px;cursor:pointer;flex:1;min-width:240px;max-width:340px\" onclick=\"ViewSystem.navigate('detail',{id:'{{id}}',title:'{{title}}',description:'{{description}}',tech:'{{tech}}',year:'{{year}}'});EventBus.emit('projectTitleSelected',{value:'{{title}}'});EventBus.emit('projectDescSelected',{value:'{{description}}'});EventBus.emit('projectTechSelected',{value:'{{tech}}'});EventBus.emit('projectParamsSelected',{value:'?view=detail&id={{id}}&title={{title}}&tech={{tech}}&year={{year}}'});\"><div style=\"font-size:10px;color:#a78bfa;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px\">{{tech}}</div><div style=\"color:#e2e8f0;font-size:17px;font-weight:700;margin-bottom:8px\">{{title}}</div><div style=\"color:#64748b;font-size:13px;line-height:1.6;margin-bottom:14px\">{{description}}</div><div style=\"font-size:11px;color:#475569\">{{year}} &nbsp;·&nbsp; Click to open detail &rarr;</div></div>"
    }
  },

  "vars": {},

  "logic": {},

  "dbCollections": [
    {
      "name": "projects",
      "seed": [
        {
          "id": "1",
          "title": "Magic Cat Engine",
          "description": "A visual no-code IDE for building interactive, database-driven profile pages using Pipes, Loops, and Views.",
          "tech": "Node.js / MongoDB",
          "year": "2026"
        },
        {
          "id": "2",
          "title": "Weather Dashboard",
          "description": "Real-time weather data visualization with animated charts and a 7-day forecast, powered by a live API Pipe.",
          "tech": "React / D3.js",
          "year": "2025"
        },
        {
          "id": "3",
          "title": "Task Manager Pro",
          "description": "Collaborative task manager with live sync, offline-first architecture, and automatic conflict resolution.",
          "tech": "Vue.js / Socket.io",
          "year": "2025"
        }
      ]
    }
  ],

